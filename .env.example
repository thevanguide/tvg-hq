# Supabase (TVG production project)
# Create a new Supabase project at https://supabase.com — separate account from any other.
# Copy URL + anon key from: Project Settings → API
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=

# Cloudflare Web Analytics — privacy-first, no cookies.
# Get the token at: Cloudflare dashboard → Analytics & Logs → Web Analytics → Site → JS snippet token.
# When set, BaseLayout injects the beacon script on every page.
PUBLIC_CF_ANALYTICS_TOKEN=

# Google Search Console site verification (meta-tag method).
# From GSC: Add Property → HTML tag → copy the value of content="…" (not the whole tag).
# When set, BaseLayout emits <meta name="google-site-verification" …> site-wide.
PUBLIC_GOOGLE_SITE_VERIFICATION=
