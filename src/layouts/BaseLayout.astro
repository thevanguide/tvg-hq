---
import "../styles/global.css";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";

interface Props {
  title: string;
  description?: string;
  noindex?: boolean;
  ogImage?: string;
  ogType?: "website" | "article";
  canonical?: string;
  showChrome?: boolean;
}

const {
  title,
  description = "Independent resource for van conversion owners and shoppers. Find builders, navigate insurance and registration, and plan your build.",
  noindex = false,
  ogImage = "/og-default.png",
  ogType = "website",
  canonical,
  showChrome = true,
} = Astro.props;

const canonicalUrl = canonical ?? new URL(Astro.url.pathname, Astro.site).toString();
const ogImageUrl = new URL(ogImage, Astro.site).toString();
const fullTitle = title.includes("The Van Guide") ? title : `${title} — The Van Guide`;

// SEO infrastructure — read from env at build time.
// Set PUBLIC_CF_ANALYTICS_TOKEN for Cloudflare Web Analytics.
// Set PUBLIC_GOOGLE_SITE_VERIFICATION for Google Search Console meta verification.
const cfAnalyticsToken = import.meta.env.PUBLIC_CF_ANALYTICS_TOKEN;
const googleSiteVerification = import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION;

// Organization JSON-LD — emitted only on the homepage.
const isHomepage = Astro.url.pathname === "/";
const siteUrl = Astro.site?.toString().replace(/\/$/, "") || "https://thevanguide.com";
const orgJsonLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "The Van Guide",
  alternateName: "TVG",
  url: siteUrl,
  logo: `${siteUrl}/logo.svg`,
  description:
    "Independent editorial resource for van conversion owners and shoppers. Builder directory, insurance and registration guides, and tools — grounded in primary sources.",
  email: "hello@thevanguide.com",
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    {googleSiteVerification && (
      <meta name="google-site-verification" content={googleSiteVerification} />
    )}
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content="The Van Guide" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=Inter:wght@400;500;600&family=Source+Serif+4:wght@400;500;600&display=swap"
      rel="stylesheet"
    />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{fullTitle}</title>

    {isHomepage && (
      <script type="application/ld+json" set:html={JSON.stringify(orgJsonLd)} />
    )}

    {cfAnalyticsToken && (
      <script
        defer
        src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={`{"token": "${cfAnalyticsToken}"}`}
      />
    )}

    <slot name="head" />
  </head>
  <body class="min-h-screen flex flex-col">
    {showChrome && <SiteHeader />}
    <main class="flex-1">
      <slot />
    </main>
    {showChrome && <SiteFooter />}
  </body>
</html>
