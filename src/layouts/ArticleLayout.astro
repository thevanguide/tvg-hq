---
import BaseLayout from "./BaseLayout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";

interface Crumb {
  label: string;
  href: string;
}

interface Props {
  title: string;
  description: string;
  publishedDate?: Date;
  lastUpdated: Date;
  author?: string;
  category?: string;
  cluster?: string;
  ogImage?: string;
  keywords?: string[];
  breadcrumbs?: Crumb[];
}

const {
  title,
  description,
  publishedDate,
  lastUpdated,
  author = "The Van Guide",
  category,
  cluster,
  ogImage,
  keywords = [],
  breadcrumbs,
} = Astro.props;

const fmtDate = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "long" });

const jsonLd: Record<string, unknown> = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: title,
  description,
  dateModified: lastUpdated.toISOString(),
  author: { "@type": "Organization", name: author },
  publisher: {
    "@type": "Organization",
    name: "The Van Guide",
    url: "https://thevanguide.com",
  },
  keywords: keywords.join(", "),
};
if (publishedDate) {
  jsonLd.datePublished = publishedDate.toISOString();
}

const eyebrow = cluster ?? category;
---

<BaseLayout title={title} description={description} ogImage={ogImage} ogType="article">
  <script is:inline type="application/ld+json" slot="head" set:html={JSON.stringify(jsonLd)} />
  <article class="py-14 md:py-20">
    <header class="container-read mb-10">
      {breadcrumbs && breadcrumbs.length > 0 && <Breadcrumbs items={breadcrumbs} />}
      {eyebrow && <div class="eyebrow mb-4">{eyebrow}</div>}
      <h1 class="text-4xl md:text-5xl leading-tight mb-5">{title}</h1>
      <p class="text-xl leading-relaxed" style="color: var(--color-text-muted);">
        {description}
      </p>
      <div class="mt-6 font-sans-ui text-sm flex gap-4" style="color: var(--color-text-subtle);">
        <span>{author}</span>
        <span aria-hidden="true">·</span>
        {publishedDate && (
          <>
            <time datetime={publishedDate.toISOString()}>Published {fmtDate(publishedDate)}</time>
            <span aria-hidden="true">·</span>
          </>
        )}
        <time datetime={lastUpdated.toISOString()}>Updated {fmtDate(lastUpdated)}</time>
      </div>
      <hr />
    </header>
    <div class="container-read prose">
      <slot />
    </div>
  </article>
</BaseLayout>
