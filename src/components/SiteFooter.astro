---
const year = new Date().getFullYear();
import EmailCapture from "./EmailCapture.astro";
---

<footer class="mt-12 md:mt-24" style="background: var(--color-primary); color: #FBFAF7;">
  <div class="container-wide py-10 md:py-14">

    <!-- Top band: newsletter + tagline -->
    <div class="grid gap-10 md:grid-cols-2 items-start pb-10 border-b" style="border-color: rgba(255,255,255,0.12);">
      <div>
        <div class="text-2xl font-semibold" style="font-family: var(--font-display); color: #FBFAF7;">
          The Van Guide
        </div>
        <p class="mt-3 max-w-md leading-relaxed" style="color: #D7D4C9; font-family: var(--font-sans); font-size: 0.95rem;">
          An independent editorial resource for van conversion owners and shoppers. Builder directory, insurance & registration guides, and tools — grounded in primary sources.
        </p>
        <div class="mt-4 inline-flex items-center gap-2 px-3 py-1 rounded-full text-xs font-medium" style="background: rgba(168,126,59,0.15); color: #D4AA66; font-family: var(--font-sans); letter-spacing: 0.04em;">
          <span style="display:inline-block; width:6px; height:6px; border-radius:50%; background:#A87E3B;"></span>
          Independent editorial
        </div>
      </div>
      <div>
        <EmailCapture variant="inline" />
      </div>
    </div>

    <!-- Link columns -->
    <div class="grid grid-cols-2 gap-x-6 gap-y-8 sm:grid-cols-3 md:grid-cols-5 pt-10 font-sans-ui text-sm">
      <div>
        <div class="uppercase tracking-wider text-xs font-semibold mb-4" style="color: #A87E3B; letter-spacing: 0.14em;">Directory</div>
        <ul class="space-y-2.5">
          <li><a href="/builders/" class="no-underline hover:underline" style="color: #E8E4D8;">All builders</a></li>
          <li><a href="/builders/california/" class="no-underline hover:underline" style="color: #E8E4D8;">California</a></li>
          <li><a href="/builders/colorado/" class="no-underline hover:underline" style="color: #E8E4D8;">Colorado</a></li>
          <li><a href="/builders/texas/" class="no-underline hover:underline" style="color: #E8E4D8;">Texas</a></li>
          <li><a href="/builders/claim/" class="no-underline hover:underline" style="color: #E8E4D8;">Claim your listing</a></li>
          <li><a href="/builders/dashboard/" class="no-underline hover:underline" style="color: #E8E4D8;">Builder dashboard</a></li>
        </ul>
      </div>
      <div>
        <div class="uppercase tracking-wider text-xs font-semibold mb-4" style="color: #A87E3B; letter-spacing: 0.14em;">Insurance</div>
        <ul class="space-y-2.5">
          <li><a href="/insurance/" class="no-underline hover:underline" style="color: #E8E4D8;">Overview</a></li>
          <li><a href="/insurance/best-for-van-conversions/" class="no-underline hover:underline" style="color: #E8E4D8;">Best carriers</a></li>
          <li><a href="/insurance/carriers/roamly/" class="no-underline hover:underline" style="color: #E8E4D8;">Roamly</a></li>
          <li><a href="/insurance/carriers/good-sam/" class="no-underline hover:underline" style="color: #E8E4D8;">Good Sam</a></li>
          <li><a href="/tools/van-insurance-finder/" class="no-underline hover:underline" style="color: #E8E4D8;">Insurance Finder</a></li>
        </ul>
      </div>
      <div>
        <div class="uppercase tracking-wider text-xs font-semibold mb-4" style="color: #A87E3B; letter-spacing: 0.14em;">Registration</div>
        <ul class="space-y-2.5">
          <li><a href="/registration/" class="no-underline hover:underline" style="color: #E8E4D8;">Overview</a></li>
          <li><a href="/registration/california/" class="no-underline hover:underline" style="color: #E8E4D8;">California</a></li>
          <li><a href="/registration/vermont-loophole/" class="no-underline hover:underline" style="color: #E8E4D8;">Vermont loophole</a></li>
          <li><a href="/certification/" class="no-underline hover:underline" style="color: #E8E4D8;">Certification</a></li>
          <li><a href="/certification/rvia/" class="no-underline hover:underline" style="color: #E8E4D8;">RVIA</a></li>
        </ul>
      </div>
      <div>
        <div class="uppercase tracking-wider text-xs font-semibold mb-4" style="color: #A87E3B; letter-spacing: 0.14em;">Tools & Guides</div>
        <ul class="space-y-2.5">
          <li><a href="/tools/" class="no-underline hover:underline" style="color: #E8E4D8;">All tools</a></li>
          <li><a href="/blog/" class="no-underline hover:underline" style="color: #E8E4D8;">Blog</a></li>
          <li><a href="/guide/" class="no-underline hover:underline" style="color: #E8E4D8;">The Playbook</a></li>
        </ul>
      </div>
      <div>
        <div class="uppercase tracking-wider text-xs font-semibold mb-4" style="color: #A87E3B; letter-spacing: 0.14em;">The Van Guide</div>
        <ul class="space-y-2.5">
          <li><a href="/about/" class="no-underline hover:underline" style="color: #E8E4D8;">About</a></li>
          <li><a href="/contact/" class="no-underline hover:underline" style="color: #E8E4D8;">Contact</a></li>
          <li><a href="/editorial-standards/" class="no-underline hover:underline" style="color: #E8E4D8;">Editorial standards</a></li>
          <li><a href="/privacy/" class="no-underline hover:underline" style="color: #E8E4D8;">Privacy</a></li>
          <li><a href="/terms/" class="no-underline hover:underline" style="color: #E8E4D8;">Terms</a></li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t" style="border-color: rgba(255,255,255,0.12);">
    <div class="container-wide py-5 flex flex-col md:flex-row items-center justify-between gap-3 font-sans-ui text-xs" style="color: #B8B5A8;">
      <div>© {year} The Van Guide. Independent editorial. Not affiliated with any insurer, carrier, or builder.</div>
      <div><a href="mailto:hello@thevanguide.com" class="no-underline hover:underline" style="color: #D4AA66;">hello@thevanguide.com</a></div>
    </div>
  </div>
</footer>
