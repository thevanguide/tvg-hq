---
const year = new Date().getFullYear();
---

<footer class="mt-24 border-t" style="border-color: var(--color-border); background: var(--color-bg-alt);">
  <div class="container-wide py-12 grid gap-10 md:grid-cols-4 font-sans-ui text-sm">
    <div class="md:col-span-1">
      <div class="text-lg font-semibold" style="font-family: var(--font-display); color: var(--color-primary);">
        The Van Guide
      </div>
      <p class="mt-3 leading-relaxed" style="color: var(--color-text-muted);">
        An independent resource for van conversion owners and shoppers.
      </p>
    </div>
    <div>
      <div class="uppercase tracking-wider text-xs font-semibold mb-3" style="color: var(--color-text-subtle);">Directory</div>
      <ul class="space-y-2">
        <li><a href="/builders/" class="no-underline" style="color: var(--color-text);">All builders</a></li>
        <li><a href="/builders/california/" class="no-underline" style="color: var(--color-text);">California</a></li>
        <li><a href="/builders/colorado/" class="no-underline" style="color: var(--color-text);">Colorado</a></li>
      </ul>
    </div>
    <div>
      <div class="uppercase tracking-wider text-xs font-semibold mb-3" style="color: var(--color-text-subtle);">Learn</div>
      <ul class="space-y-2">
        <li><a href="/insurance/" class="no-underline" style="color: var(--color-text);">Insurance</a></li>
        <li><a href="/registration/" class="no-underline" style="color: var(--color-text);">Registration</a></li>
        <li><a href="/tools/" class="no-underline" style="color: var(--color-text);">Tools</a></li>
        <li><a href="/blog/" class="no-underline" style="color: var(--color-text);">Blog</a></li>
      </ul>
    </div>
    <div>
      <div class="uppercase tracking-wider text-xs font-semibold mb-3" style="color: var(--color-text-subtle);">Site</div>
      <ul class="space-y-2">
        <li><a href="/about/" class="no-underline" style="color: var(--color-text);">About</a></li>
        <li><a href="/contact/" class="no-underline" style="color: var(--color-text);">Contact</a></li>
      </ul>
    </div>
  </div>
  <div class="border-t" style="border-color: var(--color-border);">
    <div class="container-wide py-5 flex flex-col md:flex-row items-center justify-between gap-3 font-sans-ui text-xs" style="color: var(--color-text-muted);">
      <div>© {year} The Van Guide. Independent editorial.</div>
      <div>hello@thevanguide.com</div>
    </div>
  </div>
</footer>
