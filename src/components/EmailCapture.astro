---
interface Props {
  heading?: string;
  subheading?: string;
  cta?: string;
  list?: string;
  variant?: "inline" | "card";
}

const {
  heading = "Get the van owner newsletter",
  subheading = "Insurance, registration, builder spotlights, and buying guides. One email, sent when there's something worth reading.",
  cta = "Subscribe",
  list = "newsletter",
  variant = "card",
} = Astro.props;
---

<form
  data-tvg-email-capture
  data-list={list}
  class={variant === "card"
    ? "p-8 border"
    : "p-0"}
  style={variant === "card"
    ? "background: var(--color-surface); border-color: var(--color-border); border-radius: var(--radius-lg);"
    : ""}
>
  {variant === "card" && (
    <>
      <h3 class="text-2xl mb-2">{heading}</h3>
      <p class="mb-5 text-base leading-relaxed" style="color: var(--color-text-muted);">{subheading}</p>
    </>
  )}
  <div class="flex flex-col sm:flex-row gap-2">
    <label class="sr-only" for={`tvg-email-${list}`}>Email</label>
    <input
      id={`tvg-email-${list}`}
      type="email"
      name="email"
      required
      placeholder="you@example.com"
      class="flex-1 px-4 py-3 font-sans-ui text-base border bg-white"
      style="border-color: var(--color-border-strong); border-radius: var(--radius-md); color: var(--color-text);"
    />
    <button type="submit" class="btn btn-accent" aria-label={cta}>{cta}</button>
  </div>
  <p
    data-tvg-email-msg
    class="mt-3 text-xs font-sans-ui hidden"
    style="color: var(--color-text-muted);"
  >
  </p>
</form>

<script>
  const SUPABASE_URL = import.meta.env.PUBLIC_SUPABASE_URL;
  const SUPABASE_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

  document.querySelectorAll<HTMLFormElement>("form[data-tvg-email-capture]").forEach((form) => {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const msg = form.querySelector<HTMLElement>("[data-tvg-email-msg]");
      const btn = form.querySelector<HTMLButtonElement>("button[type=submit]");
      const input = form.querySelector<HTMLInputElement>("input[type=email]");
      const email = input?.value?.trim().toLowerCase();
      const list = form.dataset.list || "newsletter";
      const source = window.location.pathname;

      if (!email || !msg) return;

      const show = (text: string) => {
        msg.textContent = text;
        msg.classList.remove("hidden");
      };

      if (!SUPABASE_URL || !SUPABASE_KEY) {
        show("Subscription system not configured. Please try again later.");
        return;
      }

      if (btn) btn.disabled = true;

      try {
        const res = await fetch(`${SUPABASE_URL}/rest/v1/rpc/subscribe_to_newsletter`, {
          method: "POST",
          headers: {
            apikey: SUPABASE_KEY,
            Authorization: `Bearer ${SUPABASE_KEY}`,
            "Content-Type": "application/json",
          },
          body: JSON.stringify({ p_email: email, p_list: list, p_source: source }),
        });

        if (res.ok) {
          show("Thanks. You're on the list.");
          form.reset();
        } else {
          const text = await res.text();
          console.warn("[tvg] subscribe failed:", res.status, text);
          show("Something went wrong. Please try again in a moment.");
        }
      } catch (err) {
        console.warn("[tvg] subscribe error:", err);
        show("Network error. Please try again.");
      } finally {
        if (btn) btn.disabled = false;
      }
    });
  });
</script>
