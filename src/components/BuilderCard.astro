---
import { stateToSlug, toUrlSlug } from "../lib/supabase";

interface Props {
  name: string;
  slug: string;
  state: string;
  city?: string;
  tagline?: string;
  platforms?: string[];
  priceTier?: "Budget" | "Mid" | "Premium" | "Luxury" | "Unknown" | string;
  description?: string;
  logoUrl?: string;
  verified?: boolean;
  reviewRating?: number;
  reviewCount?: number;
  website?: string;
}

const {
  name,
  slug,
  state,
  city,
  tagline,
  platforms = [],
  priceTier,
  description,
  logoUrl,
  verified = false,
  reviewRating,
  reviewCount,
  website,
} = Astro.props;

const stateSlug = stateToSlug(state);
const profileHref = `/builders/${stateSlug}/${slug}/`;

function platformSlug(p: string): string {
  return toUrlSlug(p);
}

function tierSlug(t: string): string {
  return toUrlSlug(t);
}

// Star display helper
function renderStars(rating: number): string {
  const full = Math.floor(rating);
  const half = rating - full >= 0.25 && rating - full < 0.75;
  const empty = 5 - full - (half ? 1 : 0);
  return "★".repeat(full) + (half ? "½" : "") + "☆".repeat(empty);
}
---

<div
  class="flex flex-col p-4 sm:p-5 border transition-all hover:shadow-md"
  style="background: var(--color-surface); border-color: var(--color-border); border-radius: var(--radius-lg); box-shadow: var(--shadow-sm);"
>
  <a href={profileHref} class="no-underline flex items-start gap-3 sm:gap-4">
    {logoUrl ? (
      <img
        src={logoUrl}
        alt={`${name} logo`}
        class="w-14 h-14 object-contain rounded shrink-0 p-1.5 border"
        style="background: var(--color-logo-bg); border-color: var(--color-border);"
        loading="lazy"
      />
    ) : (
      <div
        class="w-14 h-14 flex items-center justify-center rounded shrink-0 border"
        style="background: var(--color-logo-bg); border-color: var(--color-border);"
      >
        <img src="/images/van-icon.svg" alt="" class="w-9 h-9 opacity-30" />
      </div>
    )}
    <div class="flex-1 min-w-0">
      <div class="flex items-center gap-2">
        <h3 class="text-lg leading-tight truncate" style="color: var(--color-text);">{name}</h3>
        {verified && (
          <span
            class="text-[10px] font-sans-ui uppercase tracking-wider px-1.5 py-0.5 rounded shrink-0"
            style="background: var(--color-primary); color: var(--color-bg);"
          >
            Verified
          </span>
        )}
      </div>
      <div class="mt-1 text-sm font-sans-ui" style="color: var(--color-text-muted);">
        {city ? `${city}, ${state}` : state}
      </div>
      {tagline && (
        <p class="mt-1.5 text-sm leading-snug line-clamp-2" style="color: var(--color-text);">
          {tagline}
        </p>
      )}
    </div>
  </a>

  {/* Review stars */}
  {reviewRating != null && reviewRating > 0 && (
    <div class="mt-3 flex items-center gap-2 font-sans-ui text-sm">
      <span style="color: var(--color-accent);" aria-label={`${reviewRating} out of 5 stars`}>
        {renderStars(reviewRating)}
      </span>
      <span style="color: var(--color-text-muted);">
        {reviewRating.toFixed(1)}
        {reviewCount != null && reviewCount > 0 && ` (${reviewCount})`}
      </span>
    </div>
  )}

  {/* Badges — platforms and price tier as links */}
  {(platforms.length > 0 || priceTier) && (
    <div class="mt-3 flex flex-wrap gap-1.5">
      {platforms.map((p) => (
        <a
          href={`/builders/platform/${platformSlug(p)}/`}
          class="text-[11px] font-sans-ui px-2 py-0.5 rounded-full border no-underline transition-colors hover:border-current"
          style="border-color: var(--color-border-strong); color: var(--color-text-muted);"
        >
          {p}
        </a>
      ))}
      {priceTier && priceTier !== "Unknown" && (
        <a
          href={`/builders/tier/${tierSlug(priceTier)}/`}
          class="text-[11px] font-sans-ui px-2 py-0.5 rounded-full no-underline transition-colors"
          style="background: var(--color-bg-alt); color: var(--color-primary);"
        >
          {priceTier === "Budget" ? "$ Budget" : priceTier === "Mid" ? "$$ Mid-range" : priceTier === "Premium" ? "$$$ Premium" : priceTier === "Luxury" ? "$$$$ Luxury" : priceTier}
        </a>
      )}
    </div>
  )}

  {/* Description fallback if no tagline */}
  {!tagline && description && (
    <p class="mt-3 text-sm leading-relaxed line-clamp-3" style="color: var(--color-text-muted);">
      {description}
    </p>
  )}

  {/* CTA */}
  <div class="mt-auto pt-3 sm:pt-4 flex flex-col sm:flex-row gap-2">
    <a href={profileHref} class="btn btn-ghost text-sm !py-1.5 !px-3 flex-1 text-center">
      View Profile
    </a>
    {website && (
      <a
        href={website}
        class="btn btn-primary text-sm !py-1.5 !px-3 flex-1 text-center"
        target="_blank"
        rel="noopener noreferrer"
      >
        Visit Website
      </a>
    )}
  </div>
</div>
