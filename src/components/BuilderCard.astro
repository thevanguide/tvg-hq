---
interface Props {
  name: string;
  slug: string;
  state: string;
  city?: string;
  platforms?: string[];
  priceTier?: "Basic" | "Standard" | "Premium" | "Custom" | string;
  description?: string;
  logoUrl?: string;
  verified?: boolean;
}

const {
  name,
  slug,
  state,
  city,
  platforms = [],
  priceTier,
  description,
  logoUrl,
  verified = false,
} = Astro.props;

const stateSlug = state.toLowerCase().replace(/\s+/g, "-");
const href = `/builders/${stateSlug}/${slug}/`;
---

<a
  href={href}
  class="block p-5 no-underline border transition-all hover:-translate-y-0.5"
  style="background: var(--color-surface); border-color: var(--color-border); border-radius: var(--radius-lg); box-shadow: var(--shadow-sm);"
>
  <div class="flex items-start gap-4">
    {logoUrl ? (
      <img
        src={logoUrl}
        alt={`${name} logo`}
        class="w-14 h-14 object-contain rounded"
        style="background: var(--color-bg-alt);"
        loading="lazy"
      />
    ) : (
      <div
        class="w-14 h-14 flex items-center justify-center font-semibold text-xl rounded"
        style="background: var(--color-bg-alt); color: var(--color-primary); font-family: var(--font-display);"
      >
        {name.charAt(0)}
      </div>
    )}
    <div class="flex-1 min-w-0">
      <div class="flex items-center gap-2">
        <h3 class="text-lg leading-tight truncate">{name}</h3>
        {verified && (
          <span
            class="text-[10px] font-sans-ui uppercase tracking-wider px-1.5 py-0.5 rounded"
            style="background: var(--color-primary); color: var(--color-bg);"
          >
            Verified
          </span>
        )}
      </div>
      <div class="mt-1 text-sm font-sans-ui" style="color: var(--color-text-muted);">
        {city ? `${city}, ${state}` : state}
      </div>
    </div>
  </div>
  {description && (
    <p class="mt-3 text-sm leading-relaxed line-clamp-3" style="color: var(--color-text);">
      {description}
    </p>
  )}
  {(platforms.length > 0 || priceTier) && (
    <div class="mt-4 flex flex-wrap gap-1.5">
      {platforms.map((p) => (
        <span
          class="text-[11px] font-sans-ui px-2 py-0.5 rounded-full border"
          style="border-color: var(--color-border-strong); color: var(--color-text-muted);"
        >
          {p}
        </span>
      ))}
      {priceTier && (
        <span
          class="text-[11px] font-sans-ui px-2 py-0.5 rounded-full"
          style="background: var(--color-bg-alt); color: var(--color-primary);"
        >
          {priceTier}
        </span>
      )}
    </div>
  )}
</a>
