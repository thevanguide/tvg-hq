---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../../components/Breadcrumbs.astro";
import BuilderCard from "../../../components/BuilderCard.astro";
import BuilderMap from "../../../components/BuilderMap";
import EditListingLink from "../../../components/EditListingLink";
import {
  getServiceShopProfileShops,
  getNearbyServiceShops,
  getShopProfileUrl,
  stateToSlug,
  type Builder,
} from "../../../lib/supabase";
import { serviceShopProfileMeta, localBusinessJsonLd } from "../../../lib/seo";
import { toRenderHtml } from "../../../lib/rich-text";
import { groupServices } from "../../../lib/taxonomy";

export async function getStaticPaths() {
  // Every shop tagged as a service shop gets a /services/[state]/[slug]/
  // profile. Dual-tagged shops get this page in addition to their builder
  // profile; the page template falls back to the shared description/tagline
  // when service-specific copy isn't filled in yet.
  const shops = await getServiceShopProfileShops();
  return shops.map((s) => ({
    params: {
      state: stateToSlug(s.state),
      slug: s.slug,
    },
    props: { shop: s },
  }));
}

interface Props {
  shop: Builder;
}
const { shop } = Astro.props;

const meta = serviceShopProfileMeta(shop);
const siteUrl = Astro.site?.toString().replace(/\/$/, "") || "https://thevanguide.com";
const jsonLd = localBusinessJsonLd(shop, siteUrl, "service");

const stateSlug = stateToSlug(shop.state);
const location = shop.city ? `${shop.city}, ${shop.state}` : shop.state;

// Service-side content with graceful fallback to the shared fields for
// primary=service shops that only have the default description/tagline.
const displayDescription = shop.service_description ?? shop.description;
const displayTagline = shop.service_tagline ?? shop.tagline;
const displayPhone = shop.service_phone ?? shop.phone;
const displayEmail =
  (shop.service_emails && shop.service_emails[0]) ??
  (shop.emails && shop.emails[0]) ??
  null;
// Hero image with fallback to the builder-side hero so shops with a single
// visual identity don't need to upload two separate images.
const displayHero = shop.service_hero_image_url ?? shop.hero_image_url;

// Nearby service shops (up to 4 within 30 miles)
let nearbyShops: Awaited<ReturnType<typeof getNearbyServiceShops>> = [];
if (shop.latitude != null && shop.longitude != null) {
  nearbyShops = (
    await getNearbyServiceShops(shop.latitude, shop.longitude, 30, shop.id)
  ).slice(0, 4);
}

const currentYear = new Date().getFullYear();
const yearsInBusiness = shop.year_founded ? currentYear - shop.year_founded : null;

const breadcrumbs = [
  { label: "Home", href: "/" },
  { label: "Repairs & Services", href: "/services/" },
  { label: shop.state, href: `/services/${stateSlug}/` },
  { label: shop.name, href: `/services/${stateSlug}/${shop.slug}/` },
];

function renderStars(rating: number): string {
  const full = Math.floor(rating);
  const half = rating - full >= 0.25 && rating - full < 0.75;
  const empty = 5 - full - (half ? 1 : 0);
  return "★".repeat(full) + (half ? "½" : "") + "☆".repeat(empty);
}
---

<BaseLayout title={meta.title} description={meta.description}>
  <script is:inline type="application/ld+json" slot="head" set:html={JSON.stringify(jsonLd)} />

  {/* Breadcrumbs on the normal page background — always readable. */}
  <div class="container-wide pt-4">
    <Breadcrumbs items={breadcrumbs} />
  </div>

  {/* Hero banner — purely visual. Falls back to the builder-side hero when
      no service-specific hero is set, and to a subtle gradient otherwise. */}
  <div
    class="h-48 md:h-96 border-b"
    style={
      displayHero
        ? `border-color: var(--color-border); background: #1a1a1a url('${displayHero}?width=1600&quality=80') center/cover no-repeat;`
        : "border-color: var(--color-border); background: linear-gradient(135deg, var(--color-surface) 0%, var(--color-bg-alt) 100%);"
    }
    aria-hidden="true"
  />

  {/* Profile card — overlaps the bottom of the hero. All text lives here,
      guaranteed legible regardless of hero image content. */}
  <section class="container-wide relative -mt-12 md:-mt-20 mb-8 md:mb-12">
    <div
      class="bg-white border rounded-lg p-5 md:p-8"
      style="border-color: var(--color-border); box-shadow: 0 4px 16px rgba(0,0,0,0.06);"
    >
      <div class="flex flex-col md:flex-row md:items-start gap-4 md:gap-6">
        {shop.logo_url ? (
          <img
            src={shop.logo_url}
            alt={`${shop.name} logo`}
            class="w-20 h-20 md:w-24 md:h-24 object-contain rounded-lg shrink-0 p-2 border self-start"
            style="background: #2a2a2a; border-color: var(--color-border); box-shadow: 0 2px 8px rgba(0,0,0,0.08);"
            width="96"
            height="96"
          />
        ) : (
          <div
            class="w-20 h-20 md:w-24 md:h-24 flex items-center justify-center rounded-lg shrink-0 border self-start"
            style="background: var(--color-bg-alt); border-color: var(--color-border);"
          >
            <img src="/images/van-icon.svg" alt="" class="w-12 h-12 md:w-14 md:h-14 opacity-30" width="56" height="56" />
          </div>
        )}

        <div class="flex-1 min-w-0">
          <h1 class="text-3xl md:text-4xl leading-tight">{shop.name}</h1>

          {displayTagline && (
            <p class="mt-2 text-lg" style="color: var(--color-text-muted);">
              {displayTagline}
            </p>
          )}

          <div class="mt-2 font-sans-ui text-sm" style="color: var(--color-text-muted);">
            {location}
          </div>

          <div class="mt-4 flex flex-wrap gap-2">
            {shop.platforms.map((p) => (
              <span
                class="text-xs font-sans-ui px-3 py-1 rounded-full border"
                style="border-color: var(--color-border-strong); color: var(--color-text-muted);"
              >
                {p}
              </span>
            ))}
            {yearsInBusiness != null && yearsInBusiness >= 5 && (
              <span
                class="text-xs font-sans-ui px-3 py-1 rounded-full"
                style="background: var(--color-bg-alt); color: var(--color-text-muted);"
              >
                {yearsInBusiness}+ years
              </span>
            )}
            {shop.categories?.includes("builder") && (
              <a
                href={`/builders/${stateSlug}/${shop.slug}/`}
                class="text-xs font-sans-ui px-3 py-1 rounded-full no-underline transition-colors"
                style="background: var(--color-bg-alt); color: var(--color-primary); border: 1px solid var(--color-primary);"
                title="View this shop's van conversion builder profile"
              >
                View builder profile
              </a>
            )}
          </div>

          <div class="mt-5 flex flex-wrap gap-2 sm:gap-3">
            {shop.website && (
              <a
                href={shop.website}
                class="btn btn-primary"
                target="_blank"
                rel="noopener noreferrer"
              >
                Visit Website
              </a>
            )}
            {displayPhone && (
              <a href={`tel:${displayPhone}`} class="btn btn-ghost">
                Call {displayPhone}
              </a>
            )}
            {displayEmail && (
              <button
                class="btn btn-ghost"
                data-email={displayEmail}
                id="reveal-email-btn"
                type="button"
              >
                Email
              </button>
            )}
          </div>

          <EditListingLink client:idle builderId={shop.id} />
        </div>
      </div>
    </div>
  </section>

  {/* Claim banner */}
  {!shop.claimed && (
    <div style="background: var(--color-bg-alt); border-bottom: 1px solid var(--color-border);">
      <div class="container-wide py-3 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 sm:gap-4 max-w-4xl">
        <p class="font-sans-ui text-sm" style="color: var(--color-text-muted);">
          <strong style="color: var(--color-text);">Is this your business?</strong> Claim this listing to add photos, update your info, and get a verified badge.
        </p>
        <a
          href={`/builders/claim/?builder=${shop.slug}&state=${stateSlug}`}
          class="btn btn-accent text-sm shrink-0"
        >
          Claim this listing
        </a>
      </div>
    </div>
  )}

  <div class="container-wide py-12 md:py-16 max-w-4xl">
    {displayDescription && (
      <section class="mb-12">
        <h2 class="text-2xl mb-4">About {shop.name}</h2>
        <div class="prose" set:html={toRenderHtml(displayDescription)} />
        {shop.year_founded && (
          <p class="mt-4 font-sans-ui text-sm" style="color: var(--color-text-muted);">
            Established {shop.year_founded}
          </p>
        )}
      </section>
    )}

    {shop.gallery_urls && shop.gallery_urls.length > 0 && (
      <section class="mb-12">
        <div class="grid gap-3 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
          {shop.gallery_urls.map((url, i) => (
            <img
              src={url}
              alt={`${shop.name} photo ${i + 1}`}
              class="w-full aspect-[4/3] object-cover rounded-lg"
              style="background: var(--color-bg-alt);"
              width="600"
              height="450"
              loading={i === 0 ? "eager" : "lazy"}
            />
          ))}
        </div>
      </section>
    )}

    {shop.services.length > 0 && (
      <section class="mb-12">
        <h2 class="text-2xl mb-4">Services</h2>
        <div class="space-y-4">
          {groupServices(shop.services).map((group) => (
            <div>
              <div
                class="font-sans-ui text-xs uppercase tracking-wider mb-2"
                style="color: var(--color-text-subtle, #888);"
              >
                {group.label}
              </div>
              <div class="flex flex-wrap gap-2">
                {group.services.map((s) => (
                  <span
                    class="text-sm font-sans-ui px-3 py-1.5 rounded-full border"
                    style="border-color: var(--color-border-strong); color: var(--color-text);"
                  >
                    {s}
                  </span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </section>
    )}

    {shop.review_rating != null && shop.review_rating > 0 && (
      <section class="mb-12">
        <h2 class="text-2xl mb-4">Reviews</h2>
        <div class="flex items-center gap-3 font-sans-ui">
          <span class="text-2xl md:text-3xl" style="color: var(--color-accent);">
            {renderStars(shop.review_rating)}
          </span>
          <div>
            <div class="text-lg font-semibold">{shop.review_rating.toFixed(1)} / 5</div>
            {shop.review_count != null && shop.review_count > 0 && (
              <div class="text-sm" style="color: var(--color-text-muted);">
                Based on {shop.review_count} Google {shop.review_count === 1 ? "review" : "reviews"}
              </div>
            )}
          </div>
        </div>
        {shop.google_maps_url && (
          <a
            href={shop.google_maps_url}
            class="inline-block mt-3 font-sans-ui text-sm"
            target="_blank"
            rel="noopener noreferrer"
          >
            View on Google Maps →
          </a>
        )}
      </section>
    )}

    <section class="mb-12">
      <h2 class="text-2xl mb-4">Location</h2>
      {shop.latitude != null && shop.longitude != null && (
        <div class="mb-4">
          <BuilderMap
            client:visible
            builders={[{
              id: shop.id,
              name: shop.name,
              slug: shop.slug,
              state: shop.state,
              city: shop.city,
              latitude: shop.latitude,
              longitude: shop.longitude,
              review_rating: shop.review_rating,
              review_count: shop.review_count,
              profile_href: `/services/${stateSlug}/${shop.slug}/`,
            }]}
            singlePin={true}
            center={[shop.latitude, shop.longitude]}
            zoom={13}
          />
        </div>
      )}
      <p class="font-sans-ui">
        {shop.street && <span>{shop.street}<br /></span>}
        {location}
        {shop.postal_code && ` ${shop.postal_code}`}
      </p>
      {shop.google_maps_url && (
        <a
          href={shop.google_maps_url}
          class="inline-block mt-3 font-sans-ui text-sm"
          target="_blank"
          rel="noopener noreferrer"
        >
          Open in Google Maps →
        </a>
      )}
    </section>

    {!shop.claimed && (
      <section class="mb-12 p-5 sm:p-8 border" style="border-color: var(--color-primary); border-radius: var(--radius-lg); background: var(--color-surface);">
        <div class="flex flex-col sm:flex-row sm:items-center gap-4 sm:gap-6">
          <div class="flex-1">
            <h3 class="text-xl sm:text-2xl mb-2">Is this your business?</h3>
            <p class="font-sans-ui text-sm" style="color: var(--color-text-muted);">
              Claim this listing to add photos, update your description, and display a verified badge. Free during launch.
            </p>
          </div>
          <a
            href={`/builders/claim/?builder=${shop.slug}&state=${stateSlug}`}
            class="btn btn-accent shrink-0"
          >
            Claim this listing →
          </a>
        </div>
      </section>
    )}

    {nearbyShops.length > 0 && (
      <section class="mb-12">
        <h2 class="text-2xl mb-6">Other service shops nearby</h2>
        <div class="grid gap-4 grid-cols-1 sm:grid-cols-2">
          {nearbyShops.map((s) => (
            <BuilderCard
              name={s.name}
              slug={s.slug}
              state={s.state}
              city={s.city ?? undefined}
              tagline={s.service_tagline ?? s.tagline ?? undefined}
              platforms={s.platforms}
              priceTier={s.price_tier ?? undefined}
              description={s.service_description ?? s.description ?? undefined}
              logoUrl={s.logo_url ?? undefined}
              verified={s.verified}
              reviewRating={s.review_rating ?? undefined}
              reviewCount={s.review_count ?? undefined}
              website={s.website ?? undefined}
              basePath="/services"
              profileHref={getShopProfileUrl(s, "/services")}
            />
          ))}
        </div>
      </section>
    )}

    <section class="pt-8 border-t" style="border-color: var(--color-border);">
      <h2 class="text-xl mb-4">Related</h2>
      <ul class="space-y-2 font-sans-ui text-sm">
        <li>
          <a href={`/services/${stateSlug}/`}>All service shops in {shop.state}</a>
        </li>
        <li>
          <a href="/services/">Full service shop directory</a>
        </li>
        <li>
          <a href={`/builders/${stateSlug}/`}>Van conversion builders in {shop.state}</a>
        </li>
        <li>
          <a href="/insurance/best-for-van-conversions/">Van conversion insurance: which carriers write these policies</a>
        </li>
        <li>
          <a href={`/registration/${stateToSlug(shop.state)}/`}>How to register a converted van in {shop.state}</a>
        </li>
        <li>
          <a href="/builders/add/">Add your shop to the directory (free)</a>
        </li>
      </ul>
    </section>
  </div>
</BaseLayout>

<script>
  const btn = document.getElementById("reveal-email-btn");
  if (btn) {
    btn.addEventListener("click", () => {
      const email = btn.getAttribute("data-email");
      if (email) {
        btn.textContent = email;
        btn.removeAttribute("data-email");
        btn.classList.remove("btn-ghost");
        btn.classList.add("btn-accent");
        btn.setAttribute("disabled", "true");
      }
    });
  }
</script>
