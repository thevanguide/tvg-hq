---
import BaseLayout from "../layouts/BaseLayout.astro";
import ArticleCard from "../components/ArticleCard.astro";
import EmailCapture from "../components/EmailCapture.astro";
import { getCollection } from "astro:content";

// Cross-category latest articles — pull from all content types, sort by lastUpdated, show top 3
const isDraft = ({ data }: { data: { draft?: boolean; pillar?: boolean } }) =>
  !data.draft && !data.pillar;

const [insurance, registration, financing, blog] = await Promise.all([
  getCollection("insurance", isDraft),
  getCollection("registration", isDraft),
  getCollection("financing", isDraft),
  getCollection("blog", isDraft),
]);

const latest = [...insurance, ...registration, ...financing, ...blog]
  .sort((a, b) => b.data.lastUpdated.getTime() - a.data.lastUpdated.getTime())
  .slice(0, 3);

function hrefFor(entry: { collection: string; slug: string }) {
  return `/${entry.collection}/${entry.slug}/`;
}
---

<BaseLayout
  title="The Van Guide — From Finding a Builder to Life on the Road"
  description="Independent resource for van conversion owners and shoppers. Find builders, navigate insurance and registration, and plan your build."
  ogImage="/og/home.png"
>
  <!-- Hero: full-bleed with gradient overlay. Photo at public/images/hero.jpg -->
  <section class="relative overflow-hidden" style="min-height: 480px; border-bottom: 1px solid var(--color-border);">

    <!-- Background photo -->
    <img
      src="/images/hero.jpg"
      alt="A van on a scenic open road"
      class="absolute inset-0 w-full h-full object-cover object-bottom"
      loading="eager"
      width="1280"
      height="600"
    />

    <!-- Gradient overlay: deep pine left → transparent right -->
    <div class="absolute inset-0" style="background: linear-gradient(to right, rgba(20,51,30,0.88) 0%, rgba(20,51,30,0.65) 45%, rgba(20,51,30,0.2) 100%);"></div>

    <!-- Text -->
    <div class="relative container-wide py-24 md:py-36">
      <div class="max-w-xl">
        <h1 class="text-4xl sm:text-5xl lg:text-6xl leading-[1.05]" style="color: #FBFAF7;">
          Find a builder.<br>Navigate ownership.<br>Hit the road.
        </h1>
        <p class="mt-5 max-w-lg text-lg leading-relaxed" style="color: rgba(251,250,247,0.8);">
          A directory of van conversion shops across the US, plus source-verified guides to insurance, registration, financing, and everything that gets complicated after you decide to build one.
        </p>
        <div class="mt-7">
          <a href="/builders/" class="btn btn-accent">Search builders</a>
        </div>
      </div>
    </div>

  </section>

  <!-- Three pillars -->
  <section class="container-wide py-10 md:py-20">
    <div class="grid md:grid-cols-3 gap-4 md:gap-6">

      <a
        href="/builders/"
        class="block p-5 md:p-8 no-underline border transition-all hover:-translate-y-1"
        style="background: var(--color-surface); border-color: var(--color-border); border-radius: var(--radius-lg);"
      >
        <div class="eyebrow mb-3">Directory</div>
        <h3 class="text-xl md:text-2xl mb-3">Find a builder</h3>
        <p class="text-base leading-relaxed" style="color: var(--color-text-muted);">
          Search van conversion shops by state, platform, price range, and services. Every shop on the same terms — no paid placements.
        </p>
        <span class="inline-block mt-4 font-sans-ui text-sm" style="color: var(--color-accent);">Browse builders →</span>
      </a>

      <a
        href="/services/"
        class="block p-5 md:p-8 no-underline border transition-all hover:-translate-y-1"
        style="background: var(--color-surface); border-color: var(--color-border); border-radius: var(--radius-lg);"
      >
        <div class="eyebrow mb-3">Service & Repair</div>
        <h3 class="text-xl md:text-2xl mb-3">Find a shop</h3>
        <p class="text-base leading-relaxed" style="color: var(--color-text-muted);">
          Locate van-specialist repair and service shops near you — Sprinter mechanics, electrical upgrades, and mobile installers.
        </p>
        <span class="inline-block mt-4 font-sans-ui text-sm" style="color: var(--color-accent);">Find a shop →</span>
      </a>

      <a
        href="/insurance/"
        class="block p-5 md:p-8 no-underline border transition-all hover:-translate-y-1"
        style="background: var(--color-surface); border-color: var(--color-border); border-radius: var(--radius-lg);"
      >
        <div class="eyebrow mb-3">Guides</div>
        <h3 class="text-xl md:text-2xl mb-3">Protect, register & finance</h3>
        <p class="text-base leading-relaxed" style="color: var(--color-text-muted);">
          Which carriers write policies on converted vans. How to retitle in your state. How to finance a build. Every claim traced to the source.
        </p>
        <span class="inline-block mt-4 font-sans-ui text-sm" style="color: var(--color-accent);">Read the guides →</span>
      </a>

    </div>
  </section>

  <!-- Trust strip -->
  <section class="border-y" style="border-color: var(--color-border); background: var(--color-surface);">
    <div class="container-wide py-8 md:py-12 grid grid-cols-1 sm:grid-cols-3 gap-6 md:gap-8 text-center font-sans-ui text-sm" style="color: var(--color-text-muted);">
      <div>
        <strong class="block text-base mb-1" style="color: var(--color-text);">Source-verified</strong>
        Every factual claim links to an official carrier site, state statute, or agency document.
      </div>
      <div>
        <strong class="block text-base mb-1" style="color: var(--color-text);">No paid placements</strong>
        Directory rankings are never sold. Builders appear based on location and data, not ad spend.
      </div>
      <div>
        <strong class="block text-base mb-1" style="color: var(--color-text);">Always disclosed</strong>
        If a page includes an affiliate link or sponsored content, it says so at the top.
      </div>
    </div>
  </section>

  <!-- Latest guides — cross-category -->
  {latest.length > 0 && (
    <section class="container-wide py-10 md:py-20">
      <div class="flex items-baseline justify-between mb-6 md:mb-8">
        <h2 class="text-2xl md:text-4xl">Latest guides</h2>
        <a href="/insurance/" class="font-sans-ui text-sm">All guides →</a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-6">
        {latest.map((entry) => (
          <ArticleCard
            href={hrefFor(entry)}
            title={entry.data.title}
            description={entry.data.description}
            lastUpdated={entry.data.lastUpdated}
            cluster={entry.data.cluster}
          />
        ))}
      </div>
    </section>
  )}

  <!-- Newsletter -->
  <section class="container-wide pb-20">
    <EmailCapture />
  </section>
</BaseLayout>
