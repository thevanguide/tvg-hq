---
import BaseLayout from "../layouts/BaseLayout.astro";
import ArticleCard from "../components/ArticleCard.astro";
import EmailCapture from "../components/EmailCapture.astro";
import { getCollection } from "astro:content";

const insurance = (await getCollection("insurance", ({ data }) => !data.draft))
  .sort((a, b) => b.data.lastUpdated.getTime() - a.data.lastUpdated.getTime())
  .slice(0, 3);
---

<BaseLayout
  title="The Van Guide"
  description="Independent resource for van conversion owners and shoppers. Find builders, navigate insurance and registration, and plan your build."
  noindex={true}
>
  <!-- Hero -->
  <section style="background: var(--color-surface); border-bottom: 1px solid var(--color-border);">
    <div class="container-wide py-20 md:py-28">
      <div class="eyebrow mb-5">Independent · Editorial · Not for sale</div>
      <h1 class="text-5xl md:text-7xl max-w-4xl leading-[1.05]">
        A plain-English guide to building, owning, and insuring a custom van.
      </h1>
      <p class="mt-6 max-w-2xl text-xl leading-relaxed" style="color: var(--color-text-muted);">
        The Van Guide is an editorial resource — not a builder. Search hundreds of van conversion shops across the US, navigate the insurance and registration maze, and understand what a real build actually costs.
      </p>
      <div class="mt-9 flex flex-wrap gap-3">
        <a href="/builders/" class="btn btn-primary">Find a builder</a>
        <a href="/insurance/" class="btn btn-ghost">Start with insurance</a>
      </div>
      <div class="mt-10 pt-8 border-t flex flex-wrap gap-x-8 gap-y-3 font-sans-ui text-sm" style="border-color: var(--color-border); color: var(--color-text-muted);">
        <span><strong style="color: var(--color-primary);">Every fact</strong> traces to a primary source.</span>
        <span><strong style="color: var(--color-primary);">No pay-to-play</strong> ranking in the directory.</span>
        <span><strong style="color: var(--color-primary);">Affiliate links</strong> disclosed on every page.</span>
      </div>
    </div>
  </section>

  <!-- Three pillars -->
  <section class="container-wide py-16 md:py-20">
    <div class="eyebrow mb-4">What's here</div>
    <h2 class="text-3xl md:text-4xl max-w-2xl mb-12">Three things we do, nothing else.</h2>
    <div class="grid md:grid-cols-3 gap-6">
      <a
        href="/builders/"
        class="block p-8 no-underline border transition-all hover:-translate-y-1"
        style="background: var(--color-surface); border-color: var(--color-border); border-radius: var(--radius-lg);"
      >
        <div class="eyebrow mb-3">01 — Directory</div>
        <h3 class="text-2xl mb-3">Find a van builder</h3>
        <p class="text-base leading-relaxed" style="color: var(--color-text-muted);">
          Searchable directory of custom van conversion shops across the US. Filter by platform, price tier, and location. No pay-to-play rankings.
        </p>
      </a>
      <a
        href="/insurance/"
        class="block p-8 no-underline border transition-all hover:-translate-y-1"
        style="background: var(--color-surface); border-color: var(--color-border); border-radius: var(--radius-lg);"
      >
        <div class="eyebrow mb-3">02 — Learn</div>
        <h3 class="text-2xl mb-3">Insurance &amp; registration</h3>
        <p class="text-base leading-relaxed" style="color: var(--color-text-muted);">
          Clear, up-to-date guides on insuring and registering a custom van conversion — including the state-by-state quirks nobody warns you about.
        </p>
      </a>
      <a
        href="/tools/"
        class="block p-8 no-underline border transition-all hover:-translate-y-1"
        style="background: var(--color-surface); border-color: var(--color-border); border-radius: var(--radius-lg);"
      >
        <div class="eyebrow mb-3">03 — Tools</div>
        <h3 class="text-2xl mb-3">Interactive calculators</h3>
        <p class="text-base leading-relaxed" style="color: var(--color-text-muted);">
          Free, browser-based tools: the Van Insurance Finder, build cost estimators, and more. No email required.
        </p>
      </a>
    </div>
  </section>

  <!-- Recent articles -->
  {insurance.length > 0 && (
    <section class="container-wide pb-16 md:pb-20">
      <div class="flex items-baseline justify-between mb-8">
        <h2 class="text-3xl md:text-4xl">Latest</h2>
        <a href="/insurance/" class="font-sans-ui text-sm">All articles →</a>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {insurance.map((entry) => (
          <ArticleCard
            href={`/insurance/${entry.slug}/`}
            title={entry.data.title}
            description={entry.data.description}
            lastUpdated={entry.data.lastUpdated}
            cluster={entry.data.cluster}
          />
        ))}
      </div>
    </section>
  )}

  <!-- Newsletter -->
  <section class="container-wide pb-20">
    <EmailCapture />
  </section>
</BaseLayout>
