---
import BaseLayout from "../layouts/BaseLayout.astro";
import ArticleCard from "../components/ArticleCard.astro";
import EmailCapture from "../components/EmailCapture.astro";
import { getCollection } from "astro:content";

const insurance = (await getCollection("insurance", ({ data }) => !data.draft))
  .sort((a, b) => b.data.lastUpdated.getTime() - a.data.lastUpdated.getTime())
  .slice(0, 3);
---

<BaseLayout
  title="The Van Guide"
  description="Independent resource for van conversion owners and shoppers. Find builders, navigate insurance and registration, and plan your build."
>
  <!-- Hero -->
  <section style="background: var(--color-surface); border-bottom: 1px solid var(--color-border);">
    <div class="container-wide py-12 md:py-28">
      <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-7xl max-w-4xl leading-[1.05]">
        Find a van builder. Figure out the insurance. Skip the guesswork.
      </h1>
      <p class="mt-4 md:mt-6 max-w-2xl text-lg md:text-xl leading-relaxed" style="color: var(--color-text-muted);">
        A directory of van conversion shops across the US, plus guides to insurance, registration, and everything else that gets complicated after you decide to buy one.
      </p>
      <div class="mt-6 md:mt-9 flex flex-wrap gap-3">
        <a href="/builders/" class="btn btn-primary">Search builders</a>
        <a href="/insurance/" class="btn btn-ghost">Insurance guides</a>
      </div>
    </div>
  </section>

  <!-- Two pillars -->
  <section class="container-wide py-10 md:py-20">
    <div class="grid md:grid-cols-2 gap-4 md:gap-6">
      <a
        href="/builders/"
        class="block p-5 md:p-8 no-underline border transition-all hover:-translate-y-1"
        style="background: var(--color-surface); border-color: var(--color-border); border-radius: var(--radius-lg);"
      >
        <div class="eyebrow mb-3">Directory</div>
        <h3 class="text-xl md:text-2xl mb-3">Van conversion builders across the US</h3>
        <p class="text-base leading-relaxed" style="color: var(--color-text-muted);">
          Search by state, city, platform, price range, and services offered. Every shop is listed on the same terms — no one pays for a better position. Filter, compare, and contact builders directly.
        </p>
        <span class="inline-block mt-4 font-sans-ui text-sm" style="color: var(--color-primary);">Browse builders →</span>
      </a>
      <a
        href="/insurance/"
        class="block p-5 md:p-8 no-underline border transition-all hover:-translate-y-1"
        style="background: var(--color-surface); border-color: var(--color-border); border-radius: var(--radius-lg);"
      >
        <div class="eyebrow mb-3">Guides</div>
        <h3 class="text-xl md:text-2xl mb-3">Insurance, registration, and certification</h3>
        <p class="text-base leading-relaxed" style="color: var(--color-text-muted);">
          Which carriers actually write policies on converted vans. How to retitle in your state. What RVIA certification means and when you need it. Every claim traced to the carrier's own documents or the relevant statute.
        </p>
        <span class="inline-block mt-4 font-sans-ui text-sm" style="color: var(--color-primary);">Read the guides →</span>
      </a>
    </div>
  </section>

  <!-- Trust strip -->
  <section class="border-y" style="border-color: var(--color-border); background: var(--color-surface);">
    <div class="container-wide py-8 md:py-12 grid grid-cols-1 sm:grid-cols-3 gap-6 md:gap-8 text-center font-sans-ui text-sm" style="color: var(--color-text-muted);">
      <div>
        <strong class="block text-base mb-1" style="color: var(--color-text);">Source-verified</strong>
        Every factual claim links to an official carrier site, state statute, or agency document.
      </div>
      <div>
        <strong class="block text-base mb-1" style="color: var(--color-text);">No paid placements</strong>
        Directory rankings are never sold. Builders appear based on location and data, not ad spend.
      </div>
      <div>
        <strong class="block text-base mb-1" style="color: var(--color-text);">Always disclosed</strong>
        If a page includes an affiliate link or sponsored content, it says so at the top.
      </div>
    </div>
  </section>

  <!-- Recent articles -->
  {insurance.length > 0 && (
    <section class="container-wide py-10 md:py-20">
      <div class="flex items-baseline justify-between mb-6 md:mb-8">
        <h2 class="text-2xl md:text-4xl">Latest</h2>
        <a href="/insurance/" class="font-sans-ui text-sm">All articles →</a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-6">
        {insurance.map((entry) => (
          <ArticleCard
            href={`/insurance/${entry.slug}/`}
            title={entry.data.title}
            description={entry.data.description}
            lastUpdated={entry.data.lastUpdated}
            cluster={entry.data.cluster}
          />
        ))}
      </div>
    </section>
  )}

  <!-- Newsletter -->
  <section class="container-wide pb-20">
    <EmailCapture />
  </section>
</BaseLayout>
