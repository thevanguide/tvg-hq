---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="The Van Guide — Coming Soon"
  description="The Van Guide — your resource for finding custom van builders, understanding van conversion costs, and navigating van insurance. Launching soon."
  noindex={true}
>
  <main class="min-h-screen flex items-center justify-center px-6 py-16 text-center">
    <div class="max-w-xl">
      <div
        class="inline-block text-xs tracking-[0.25em] uppercase mb-8 font-sans"
        style="color: var(--color-accent); font-family: -apple-system, sans-serif;"
      >
        — Launching 2026 —
      </div>
      <h1
        class="text-5xl md:text-7xl font-bold leading-[1.05] mb-6"
        style="color: var(--color-primary);"
      >
        The Van Guide
      </h1>
      <div
        class="w-16 h-[2px] mx-auto mb-6"
        style="background: var(--color-accent);"
      >
      </div>
      <p
        class="text-lg md:text-xl leading-relaxed mb-4 italic"
        style="color: var(--color-text);"
      >
        A neutral resource for finding van builders, comparing conversions,
        and navigating the custom van buying journey.
      </p>
      <p class="text-base mt-6" style="color: var(--color-muted)">
        We're putting something great together. Check back soon.
      </p>
      <footer
        class="mt-16 text-sm font-sans"
        style="color: var(--color-muted); font-family: -apple-system, sans-serif;"
      >
        Questions?
        <a
          href="mailto:hello@thevanguide.com"
          style="color: var(--color-primary); text-decoration: underline; text-underline-offset: 3px;"
          >hello@thevanguide.com</a
        >
      </footer>
    </div>
  </main>
</BaseLayout>
