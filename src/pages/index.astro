---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="The Van Guide — Coming Soon"
  description="The Van Guide — your resource for finding custom van builders, understanding van conversion costs, and navigating van insurance. Launching soon."
  noindex={true}
>
  <main class="min-h-screen flex items-center justify-center px-6 py-16 text-center">
    <div class="max-w-xl">
      <div
        class="inline-block text-xs tracking-[0.2em] uppercase mb-6"
        style="color: var(--color-accent)"
      >
        Launching 2026
      </div>
      <h1 class="text-4xl md:text-6xl font-bold leading-tight mb-4">
        The <span style="color: var(--color-accent)">Van</span> Guide
      </h1>
      <p
        class="text-lg leading-relaxed mb-4"
        style="color: var(--color-muted)"
      >
        Your resource for finding van builders, comparing builds, and
        navigating the custom van world.
      </p>
      <p class="text-base" style="color: var(--color-muted)">
        We're putting something great together. Check back soon.
      </p>
      <footer class="mt-12 text-sm" style="color: var(--color-muted)">
        Questions?
        <a
          href="mailto:hello@thevanguide.com"
          style="color: var(--color-accent)"
          class="no-underline hover:underline">hello@thevanguide.com</a
        >
      </footer>
    </div>
  </main>
</BaseLayout>
