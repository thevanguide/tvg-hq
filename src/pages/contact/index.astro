---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Contact"
  description="Get in touch with The Van Guide — corrections, tips, builder listings, and press inquiries."
>
  <section class="container-read py-16 md:py-24">
    <div class="eyebrow mb-4">Contact</div>
    <h1 class="text-4xl md:text-5xl leading-tight mb-6">Get in touch.</h1>
    <div class="prose">
      <p>
        Corrections, tips, press inquiries, and builders who want to be listed — email <a href="mailto:hello@thevanguide.com">hello@thevanguide.com</a>.
      </p>
      <h2>What to include</h2>
      <ul>
        <li><strong>Corrections:</strong> the URL and the specific claim that needs fixing.</li>
        <li><strong>New listings:</strong> shop name, state, website, and any platforms they build on.</li>
        <li><strong>Press:</strong> outlet, deadline, and the angle you're working on.</li>
      </ul>
      <p>We try to respond within a few business days.</p>
    </div>
  </section>
</BaseLayout>
