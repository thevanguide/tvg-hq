---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ArticleCard from "../../components/ArticleCard.astro";
import { getCollection } from "astro:content";
import { faqPageJsonLd } from "../../lib/seo";

const all = await getCollection("insurance", ({ data }) => !data.draft);
const pillar = all.find((e) => e.data.pillar);
const others = all
  .filter((e) => !e.data.pillar)
  .sort((a, b) => a.data.title.localeCompare(b.data.title));

const clusters = new Map<string, typeof others>();
for (const entry of others) {
  const key = entry.data.cluster ?? "Guides";
  if (!clusters.has(key)) clusters.set(key, []);
  clusters.get(key)!.push(entry);
}

const { Content: PillarContent } = pillar
  ? await pillar.render()
  : { Content: null };

const title = pillar?.data.title ?? "Van Insurance Guide";
const description =
  pillar?.data.description ??
  "Plain-language guides to insuring a custom van conversion.";
const lastUpdated = pillar?.data.lastUpdated;

const fmtDate = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "long" });

const insuranceFaqs = [
  {
    question: "What is the best insurance for a converted van?",
    answer: "The best insurance for a converted van depends on your build and usage. For professionally built vans, Progressive and Good Sam offer RV policies that cover the conversion value. For DIY builds or vans without RVIA certification, Roamly is purpose-built for van life and offers agreed-value coverage without requiring certification. State Farm can work through local agents but coverage varies by state. The Van Guide's insurance hub compares all major carriers side by side.",
  },
  {
    question: "Do I need special insurance for a van conversion?",
    answer: "Yes. Standard auto insurance does not cover the value of a van conversion — it only covers the base vehicle. To protect your build investment, you need either an RV policy or a specialty policy that covers the conversion value separately. Some carriers offer agreed-value coverage, which pays out a pre-set amount rather than depreciated value.",
  },
  {
    question: "How much does van conversion insurance cost?",
    answer: "Van conversion insurance typically costs $1,000 to $3,000 per year, depending on the insured value, your driving record, where you live, and whether you use the van full-time. Agreed-value policies that cover the full build cost generally run higher than actual-cash-value policies. Full-time use and high-value builds increase premiums.",
  },
  {
    question: "Can I insure a DIY van conversion?",
    answer: "Yes, but your options are more limited. Roamly covers DIY builds without requiring RVIA certification. Progressive may cover DIY conversions classified as RVs in some states. Traditional carriers like State Farm and GEICO are less likely to issue RV policies for self-built conversions. Documentation of your build (receipts, photos, appraisals) helps when applying for coverage.",
  },
];
---

<BaseLayout title={title} description={description} ogType="article" ogImage="/og/insurance-hub.png">
  <article class="py-14 md:py-20">
    <header class="container-read mb-10">
      <div class="eyebrow mb-4">Insurance</div>
      <h1 class="text-3xl md:text-5xl leading-tight mb-5">{title}</h1>
      <p class="text-lg md:text-xl leading-relaxed" style="color: var(--color-text-muted);">
        {description}
      </p>
      {lastUpdated && (
        <div class="mt-6 font-sans-ui text-sm" style="color: var(--color-text-subtle);">
          <time datetime={lastUpdated.toISOString()}>Last updated {fmtDate(lastUpdated)}</time>
        </div>
      )}
      <hr />
    </header>
    {PillarContent && (
      <div class="container-read prose">
        <PillarContent />
      </div>
    )}
  </article>

  {/* FAQ section — visible content for AEO */}
  <section class="container-wide py-14 md:py-20">
    <h2 class="text-2xl md:text-4xl mb-6">Frequently asked questions</h2>
    <dl class="space-y-6 max-w-3xl">
      {insuranceFaqs.map((faq) => (
        <div>
          <dt class="font-sans-ui font-semibold text-lg mb-2">{faq.question}</dt>
          <dd style="color: var(--color-text-muted);">{faq.answer}</dd>
        </div>
      ))}
    </dl>
  </section>

  {/* FAQPage structured data */}
  <script type="application/ld+json" set:html={JSON.stringify(faqPageJsonLd(insuranceFaqs))} />

  {others.length > 0 && (
    <section class="border-t py-14 md:py-20" style="border-color: var(--color-border); background: var(--color-surface);">
      <div class="container-wide">
        <h2 class="text-2xl md:text-4xl mb-3">Deeper into insurance</h2>
        <p class="text-lg mb-10 max-w-2xl" style="color: var(--color-text-muted);">
          Carrier reviews, vehicle-specific guides, and decision frameworks for specific situations.
        </p>
        {[...clusters.entries()].map(([clusterName, entries]) => (
          <div class="mb-12">
            <h3 class="text-xl mb-5 font-sans-ui tracking-wide uppercase" style="color: var(--color-text-subtle);">
              {clusterName}
            </h3>
            <div class="grid gap-4 grid-cols-1 md:grid-cols-2 lg:grid-cols-3">
              {entries.map((entry) => (
                <ArticleCard
                  href={`/insurance/${entry.slug}/`}
                  title={entry.data.title}
                  description={entry.data.description}
                  lastUpdated={entry.data.lastUpdated}
                  cluster={entry.data.cluster}
                />
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>
  )}
</BaseLayout>
