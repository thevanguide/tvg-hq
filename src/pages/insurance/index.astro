---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ArticleCard from "../../components/ArticleCard.astro";
import { getCollection } from "astro:content";

const all = await getCollection("insurance", ({ data }) => !data.draft);
const pillar = all.find((e) => e.data.pillar);
const others = all
  .filter((e) => !e.data.pillar)
  .sort((a, b) => a.data.title.localeCompare(b.data.title));

const clusters = new Map<string, typeof others>();
for (const entry of others) {
  const key = entry.data.cluster ?? "Guides";
  if (!clusters.has(key)) clusters.set(key, []);
  clusters.get(key)!.push(entry);
}

const { Content: PillarContent } = pillar
  ? await pillar.render()
  : { Content: null };

const title = pillar?.data.title ?? "Van Insurance Guide";
const description =
  pillar?.data.description ??
  "Plain-language guides to insuring a custom van conversion.";
const lastUpdated = pillar?.data.lastUpdated;

const fmtDate = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "long" });
---

<BaseLayout title={title} description={description} ogType="article" ogImage="/og/insurance-hub.png">
  <article class="py-14 md:py-20">
    <header class="container-read mb-10">
      <div class="eyebrow mb-4">Insurance</div>
      <h1 class="text-3xl md:text-5xl leading-tight mb-5">{title}</h1>
      <p class="text-lg md:text-xl leading-relaxed" style="color: var(--color-text-muted);">
        {description}
      </p>
      {lastUpdated && (
        <div class="mt-6 font-sans-ui text-sm" style="color: var(--color-text-subtle);">
          <time datetime={lastUpdated.toISOString()}>Last updated {fmtDate(lastUpdated)}</time>
        </div>
      )}
      <hr />
    </header>
    {PillarContent && (
      <div class="container-read prose">
        <PillarContent />
      </div>
    )}
  </article>

  {others.length > 0 && (
    <section class="border-t py-14 md:py-20" style="border-color: var(--color-border); background: var(--color-surface);">
      <div class="container-wide">
        <h2 class="text-2xl md:text-4xl mb-3">Deeper into insurance</h2>
        <p class="text-lg mb-10 max-w-2xl" style="color: var(--color-text-muted);">
          Carrier reviews, vehicle-specific guides, and decision frameworks for specific situations.
        </p>
        {[...clusters.entries()].map(([clusterName, entries]) => (
          <div class="mb-12">
            <h3 class="text-xl mb-5 font-sans-ui tracking-wide uppercase" style="color: var(--color-text-subtle);">
              {clusterName}
            </h3>
            <div class="grid gap-4 grid-cols-1 md:grid-cols-2 lg:grid-cols-3">
              {entries.map((entry) => (
                <ArticleCard
                  href={`/insurance/${entry.slug}/`}
                  title={entry.data.title}
                  description={entry.data.description}
                  lastUpdated={entry.data.lastUpdated}
                  cluster={entry.data.cluster}
                />
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>
  )}
</BaseLayout>
