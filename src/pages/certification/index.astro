---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ArticleCard from "../../components/ArticleCard.astro";
import { getCollection } from "astro:content";

const all = await getCollection("certification", ({ data }) => !data.draft);
const pillar = all.find((e) => e.data.pillar);
const others = all
  .filter((e) => !e.data.pillar)
  .sort((a, b) => a.data.title.localeCompare(b.data.title));

const { Content: PillarContent } = pillar
  ? await pillar.render()
  : { Content: null };

const title = pillar?.data.title ?? "Van Conversion Certification";
const description =
  pillar?.data.description ??
  "RVIA, NOAH, NFPA 1192 — what the seals mean and when they matter.";
const lastUpdated = pillar?.data.lastUpdated;

const fmtDate = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "long" });
---

<BaseLayout title={title} description={description} ogType="article">
  <article class="py-14 md:py-20">
    <header class="container-read mb-10">
      <div class="eyebrow mb-4">Certification</div>
      <h1 class="text-3xl md:text-5xl leading-tight mb-5">{title}</h1>
      <p class="text-lg md:text-xl leading-relaxed" style="color: var(--color-text-muted);">
        {description}
      </p>
      {lastUpdated && (
        <div class="mt-6 font-sans-ui text-sm" style="color: var(--color-text-subtle);">
          <time datetime={lastUpdated.toISOString()}>Last updated {fmtDate(lastUpdated)}</time>
        </div>
      )}
      <hr />
    </header>
    {PillarContent && (
      <div class="container-read prose">
        <PillarContent />
      </div>
    )}
  </article>

  {others.length > 0 && (
    <section class="border-t py-14 md:py-20" style="border-color: var(--color-border); background: var(--color-surface);">
      <div class="container-wide">
        <h2 class="text-2xl md:text-4xl mb-3">Certification guides</h2>
        <p class="text-base md:text-lg mb-8 md:mb-10 max-w-2xl" style="color: var(--color-text-muted);">
          Deep dives on specific certifications, standards, and what they change for van conversions.
        </p>
        <div class="grid gap-4 grid-cols-1 md:grid-cols-2 lg:grid-cols-3">
          {others.map((entry) => (
            <ArticleCard
              href={`/certification/${entry.slug}/`}
              title={entry.data.title}
              description={entry.data.description}
              lastUpdated={entry.data.lastUpdated}
              cluster={entry.data.cluster}
            />
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>
