---
import DirectoryLayout from "../../../layouts/DirectoryLayout.astro";
import BuilderCard from "../../../components/BuilderCard.astro";
import { getAllBuilders } from "../../../lib/supabase";
import { platformMeta } from "../../../lib/seo";

export async function getStaticPaths() {
  const builders = await getAllBuilders();
  const platforms = new Set<string>();
  for (const b of builders) {
    for (const p of b.platforms) {
      platforms.add(p);
    }
  }
  // Seed common platforms so routes exist even with empty DB
  ["Sprinter", "ProMaster", "Transit"].forEach((p) => platforms.add(p));

  return [...platforms].map((platform) => ({
    params: { platform: platform.toLowerCase().replace(/\s+/g, "-") },
    props: { platformName: platform },
  }));
}

interface Props {
  platformName: string;
}
const { platformName } = Astro.props;

const all = await getAllBuilders();
const builders = all.filter((b) =>
  b.platforms.some((p) => p.toLowerCase() === platformName.toLowerCase()),
);

const sorted = [...builders].sort((a, b) => {
  const rA = a.review_rating ?? 0;
  const rB = b.review_rating ?? 0;
  if (rB !== rA) return rB - rA;
  return (b.review_count ?? 0) - (a.review_count ?? 0);
});

const meta = platformMeta(platformName, builders.length);

const breadcrumbs = [
  { label: "Home", href: "/" },
  { label: "Builders", href: "/builders/" },
  { label: "Platform", href: "/builders/" },
  { label: platformName, href: `/builders/platform/${platformName.toLowerCase().replace(/\s+/g, "-")}/` },
];

// Related categories
const otherPlatforms = ["Sprinter", "ProMaster", "Transit"].filter(
  (p) => p.toLowerCase() !== platformName.toLowerCase(),
);
---

<DirectoryLayout
  title={meta.title}
  description={meta.description}
  eyebrow="Platform"
  heading={`${platformName} Van Conversion Builders`}
  intro={builders.length > 0
    ? `${builders.length} van conversion ${builders.length === 1 ? "shop" : "shops"} building on the ${platformName} platform across the US.`
    : `No ${platformName} builders listed yet. Check back soon.`}
  breadcrumbs={breadcrumbs}
>
  {builders.length === 0 ? (
    <div
      class="p-10 text-center border border-dashed"
      style="border-color: var(--color-border-strong); border-radius: var(--radius-lg); background: var(--color-surface);"
    >
      <h2 class="text-xl mb-2">No listings yet</h2>
      <p style="color: var(--color-text-muted);">
        We're still adding {platformName} builders to the directory.
      </p>
    </div>
  ) : (
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {sorted.map((b) => (
        <BuilderCard
          name={b.name}
          slug={b.slug}
          state={b.state}
          city={b.city ?? undefined}
          tagline={b.tagline ?? undefined}
          platforms={b.platforms}
          priceTier={b.price_tier ?? undefined}
          description={b.description ?? undefined}
          logoUrl={b.logo_url ?? undefined}
          verified={b.verified}
          reviewRating={b.review_rating ?? undefined}
          reviewCount={b.review_count ?? undefined}
          website={b.website ?? undefined}
        />
      ))}
    </div>
  )}

  {/* Cross-links */}
  <nav class="mt-12 pt-8 border-t font-sans-ui text-sm flex flex-wrap gap-x-6 gap-y-2" style="border-color: var(--color-border);">
    <a href="/builders/">← All builders</a>
    {otherPlatforms.map((p) => (
      <a href={`/builders/platform/${p.toLowerCase()}/`}>{p} builders</a>
    ))}
    <a href="/builders/tier/premium/">Premium builders</a>
    <a href="/builders/service/off-grid/">Off-grid specialists</a>
  </nav>
</DirectoryLayout>
