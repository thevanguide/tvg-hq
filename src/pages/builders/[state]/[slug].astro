---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../../components/Breadcrumbs.astro";
import BuilderCard from "../../../components/BuilderCard.astro";
import BuilderMap from "../../../components/BuilderMap";
import EditListingLink from "../../../components/EditListingLink";
import {
  getAllBuilders,
  getNearbyBuilders,
  stateToSlug,
  toUrlSlug,
  type Builder,
} from "../../../lib/supabase";
import { profileMeta, localBusinessJsonLd } from "../../../lib/seo";

export async function getStaticPaths() {
  const builders = await getAllBuilders();
  return builders.map((b) => ({
    params: {
      state: stateToSlug(b.state),
      slug: b.slug,
    },
    props: { builder: b },
  }));
}

interface Props {
  builder: Builder;
}
const { builder } = Astro.props;

const meta = profileMeta(builder);
const siteUrl = Astro.site?.toString().replace(/\/$/, "") || "https://thevanguide.com";
const jsonLd = localBusinessJsonLd(builder, siteUrl);

const stateSlug = stateToSlug(builder.state);
const location = builder.city
  ? `${builder.city}, ${builder.state}`
  : builder.state;

// Nearby builders (2-4 within ~30 miles)
let nearbyBuilders: Awaited<ReturnType<typeof getNearbyBuilders>> = [];
if (builder.latitude != null && builder.longitude != null) {
  nearbyBuilders = (
    await getNearbyBuilders(builder.latitude, builder.longitude, 30, builder.id)
  ).slice(0, 4);
}

// Years in business
const currentYear = new Date().getFullYear();
const yearsInBusiness = builder.year_founded
  ? currentYear - builder.year_founded
  : null;

const breadcrumbs = [
  { label: "Home", href: "/" },
  { label: "Builders", href: "/builders/" },
  { label: builder.state, href: `/builders/${stateSlug}/` },
  { label: builder.name, href: `/builders/${stateSlug}/${builder.slug}/` },
];

// Star display helper
function renderStars(rating: number): string {
  const full = Math.floor(rating);
  const half = rating - full >= 0.25 && rating - full < 0.75;
  const empty = 5 - full - (half ? 1 : 0);
  return "★".repeat(full) + (half ? "½" : "") + "☆".repeat(empty);
}

function platformSlug(p: string): string {
  return toUrlSlug(p);
}
---

<BaseLayout title={meta.title} description={meta.description}>
  <script is:inline type="application/ld+json" slot="head" set:html={JSON.stringify(jsonLd)} />

  {/* Hero section */}
  <section class="border-b" style="border-color: var(--color-border); background: var(--color-surface);">
    <div class="container-wide py-10 md:py-20">
      <Breadcrumbs items={breadcrumbs} />

      <div class="flex flex-col md:flex-row md:items-start gap-4 md:gap-6">
        {/* Logo or initial */}
        {builder.logo_url ? (
          <img
            src={builder.logo_url}
            alt={`${builder.name} logo`}
            class="w-16 h-16 md:w-20 md:h-20 object-contain rounded-lg shrink-0 p-2 border"
            style="background: #2a2a2a; border-color: var(--color-border);"
          />
        ) : (
          <div
            class="w-16 h-16 md:w-20 md:h-20 flex items-center justify-center rounded-lg shrink-0 border"
            style="background: var(--color-bg-alt); border-color: var(--color-border);"
          >
            <img src="/images/van-icon.svg" alt="" class="w-10 h-10 md:w-12 md:h-12 opacity-30" />
          </div>
        )}

        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-3 flex-wrap">
            <h1 class="text-3xl md:text-5xl leading-tight">{builder.name}</h1>
            {builder.verified && (
              <span
                class="text-xs font-sans-ui uppercase tracking-wider px-2 py-1 rounded shrink-0"
                style="background: var(--color-primary); color: var(--color-bg);"
                title="This listing is owner-verified"
              >
                Verified
              </span>
            )}
          </div>

          {builder.tagline && (
            <p class="mt-2 text-lg" style="color: var(--color-text-muted);">
              {builder.tagline}
            </p>
          )}

          <div class="mt-3 font-sans-ui text-sm" style="color: var(--color-text-muted);">
            {location}
          </div>

          {/* Badges row */}
          <div class="mt-4 flex flex-wrap gap-2">
            {builder.platforms.map((p) => (
              <a
                href={`/builders/platform/${platformSlug(p)}/`}
                class="text-xs font-sans-ui px-3 py-1 rounded-full border no-underline transition-colors hover:border-current"
                style="border-color: var(--color-border-strong); color: var(--color-text-muted);"
              >
                {p}
              </a>
            ))}
            {builder.price_tier && builder.price_tier !== "Unknown" && (
              <a
                href={`/builders/tier/${builder.price_tier.toLowerCase()}/`}
                class="text-xs font-sans-ui px-3 py-1 rounded-full no-underline"
                style="background: var(--color-bg-alt); color: var(--color-primary);"
              >
                {builder.price_tier === "Budget" ? "$ Budget" : builder.price_tier === "Mid" ? "$$ Mid-range" : builder.price_tier === "Premium" ? "$$$ Premium" : builder.price_tier === "Luxury" ? "$$$$ Luxury" : builder.price_tier}
              </a>
            )}
            {builder.build_style === "Custom" && (
              <a
                href="/builders/style/custom/"
                class="text-xs font-sans-ui px-3 py-1 rounded-full no-underline"
                style="background: var(--color-bg-alt); color: var(--color-primary);"
              >
                Custom builds
              </a>
            )}
            {yearsInBusiness != null && yearsInBusiness >= 5 && (
              <span
                class="text-xs font-sans-ui px-3 py-1 rounded-full"
                style="background: var(--color-bg-alt); color: var(--color-text-muted);"
              >
                {yearsInBusiness}+ years
              </span>
            )}
          </div>

          {/* CTAs */}
          <div class="mt-5 md:mt-6 flex flex-wrap gap-2 sm:gap-3">
            {builder.website && (
              <a
                href={builder.website}
                class="btn btn-primary"
                target="_blank"
                rel="noopener noreferrer"
              >
                Visit Website
              </a>
            )}
            {builder.phone && (
              <a href={`tel:${builder.phone}`} class="btn btn-ghost">
                Call {builder.phone}
              </a>
            )}
            {builder.emails && builder.emails.length > 0 && (
              <button
                class="btn btn-ghost"
                data-email={builder.emails[0]}
                id="reveal-email-btn"
                type="button"
              >
                Contact
              </button>
            )}
          </div>

          {/* Owner-only edit link (renders nothing if not the owner) */}
          <EditListingLink client:idle builderId={builder.id} />
        </div>
      </div>
    </div>
  </section>

  {/* Claim banner — right below hero, above content */}
  {!builder.claimed && (
    <div style="background: var(--color-bg-alt); border-bottom: 1px solid var(--color-border);">
      <div class="container-wide py-3 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 sm:gap-4 max-w-4xl">
        <p class="font-sans-ui text-sm" style="color: var(--color-text-muted);">
          <strong style="color: var(--color-text);">Is this your business?</strong> Claim this listing to add photos, update your info, and get a verified badge.
        </p>
        <a
          href={`/builders/claim/?builder=${builder.slug}&state=${stateSlug}`}
          class="btn btn-accent text-sm shrink-0"
        >
          Claim this listing
        </a>
      </div>
    </div>
  )}

  {/* Owner disclosure — ECB only */}
  {builder.slug === "emery-custom-builds" && (
    <div style="background: var(--color-bg-alt); border-bottom: 1px solid var(--color-border);">
      <div class="container-wide py-3 max-w-4xl">
        <p class="font-sans-ui text-sm" style="color: var(--color-text-muted);">
          <strong style="color: var(--color-text);">Disclosure:</strong> This shop is operated by the founder of The Van Guide. It is listed under the same criteria as every other builder and receives no preferential placement.
          <a href="/builders/how-we-review/#conflicts-of-interest" class="ml-1">Learn more →</a>
        </p>
      </div>
    </div>
  )}

  <div class="container-wide py-12 md:py-16 max-w-4xl">
    {/* About section */}
    {builder.description && (
      <section class="mb-12">
        <h2 class="text-2xl mb-4">About {builder.name}</h2>
        <div class="prose">
          <p>{builder.description}</p>
        </div>
        {builder.year_founded && (
          <p class="mt-4 font-sans-ui text-sm" style="color: var(--color-text-muted);">
            Established {builder.year_founded}
          </p>
        )}
      </section>
    )}

    {/* Gallery — only show if photos exist */}
    {builder.gallery_urls && builder.gallery_urls.length > 0 && (
      <section class="mb-12">
        <div class="grid gap-3 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
          {builder.gallery_urls.map((url, i) => (
            <img
              src={url}
              alt={`${builder.name} build photo ${i + 1}`}
              class="w-full aspect-[4/3] object-cover rounded-lg"
              style="background: var(--color-bg-alt);"
              loading={i === 0 ? "eager" : "lazy"}
            />
          ))}
        </div>
      </section>
    )}

    {/* Services & platforms */}
    {(builder.services.length > 0 || builder.platforms.length > 0) && (
      <section class="mb-12">
        <h2 class="text-2xl mb-4">Services &amp; platforms</h2>
        <div class="grid sm:grid-cols-2 gap-6">
          {builder.platforms.length > 0 && (
            <div>
              <div class="eyebrow mb-3">Platforms</div>
              <div class="flex flex-wrap gap-2">
                {builder.platforms.map((p) => (
                  <a
                    href={`/builders/platform/${platformSlug(p)}/`}
                    class="text-sm font-sans-ui px-3 py-1.5 rounded-full border no-underline transition-colors hover:border-current"
                    style="border-color: var(--color-border-strong); color: var(--color-text);"
                  >
                    {p}
                  </a>
                ))}
              </div>
            </div>
          )}
          {builder.services.length > 0 && (
            <div>
              <div class="eyebrow mb-3">Services</div>
              <div class="flex flex-wrap gap-2">
                {builder.services.map((s) => {
                  const serviceSlug = toUrlSlug(s);
                  return (
                    <a
                      href={`/builders/service/${serviceSlug}/`}
                      class="text-sm font-sans-ui px-3 py-1.5 rounded-full border no-underline transition-colors hover:border-current"
                      style="border-color: var(--color-border-strong); color: var(--color-text);"
                    >
                      {s}
                    </a>
                  );
                })}
              </div>
            </div>
          )}
        </div>
      </section>
    )}

    {/* Pricing section */}
    {builder.price_tier && (
      <section class="mb-12">
        <h2 class="text-2xl mb-4">Pricing</h2>
        <p class="font-sans-ui">
          Based on publicly available information, this builder falls in the <strong>{builder.price_tier === "Budget" ? "budget" : builder.price_tier === "Mid" ? "mid-range" : builder.price_tier === "Premium" ? "premium" : builder.price_tier === "Luxury" ? "luxury" : builder.price_tier?.toLowerCase()}</strong> price range.
        </p>
        {builder.price_evidence && (
          <p class="mt-2 text-sm" style="color: var(--color-text-muted);">
            {builder.price_evidence}
          </p>
        )}
        <p class="mt-3 text-sm" style="color: var(--color-text-muted);">
          Pricing varies by platform, layout, and options. Contact this builder directly for an accurate quote.
        </p>
      </section>
    )}

    {/* Reviews & reputation */}
    {builder.review_rating != null && builder.review_rating > 0 && (
      <section class="mb-12">
        <h2 class="text-2xl mb-4">Reviews</h2>
        <div class="flex items-center gap-3 font-sans-ui">
          <span class="text-2xl md:text-3xl" style="color: var(--color-accent);">
            {renderStars(builder.review_rating)}
          </span>
          <div>
            <div class="text-lg font-semibold">{builder.review_rating.toFixed(1)} / 5</div>
            {builder.review_count != null && builder.review_count > 0 && (
              <div class="text-sm" style="color: var(--color-text-muted);">
                Based on {builder.review_count} Google {builder.review_count === 1 ? "review" : "reviews"}
              </div>
            )}
          </div>
        </div>
        {builder.google_maps_url && (
          <a
            href={builder.google_maps_url}
            class="inline-block mt-3 font-sans-ui text-sm"
            target="_blank"
            rel="noopener noreferrer"
          >
            View on Google Maps →
          </a>
        )}
      </section>
    )}

    {/* Location */}
    <section class="mb-12">
      <h2 class="text-2xl mb-4">Location</h2>
      {builder.latitude != null && builder.longitude != null && (
        <div class="mb-4">
          <BuilderMap
            client:visible
            builders={[{
              id: builder.id,
              name: builder.name,
              slug: builder.slug,
              state: builder.state,
              city: builder.city,
              latitude: builder.latitude,
              longitude: builder.longitude,
              review_rating: builder.review_rating,
              review_count: builder.review_count,
            }]}
            singlePin={true}
            center={[builder.latitude, builder.longitude]}
            zoom={13}
          />
        </div>
      )}
      <p class="font-sans-ui">
        {builder.street && <span>{builder.street}<br /></span>}
        {location}
        {builder.postal_code && ` ${builder.postal_code}`}
      </p>
      {builder.google_maps_url && (
        <a
          href={builder.google_maps_url}
          class="inline-block mt-3 font-sans-ui text-sm"
          target="_blank"
          rel="noopener noreferrer"
        >
          Open in Google Maps →
        </a>
      )}
    </section>

    {/* Claim listing CTA — above nearby builders */}
    {!builder.claimed && (
      <section class="mb-12 p-5 sm:p-8 border" style="border-color: var(--color-primary); border-radius: var(--radius-lg); background: var(--color-surface);">
        <div class="flex flex-col sm:flex-row sm:items-center gap-4 sm:gap-6">
          <div class="flex-1">
            <h3 class="text-xl sm:text-2xl mb-2">Is this your business?</h3>
            <p class="font-sans-ui text-sm" style="color: var(--color-text-muted);">
              Claim this listing to add photos, update your description, and display a verified badge. Free during launch.
            </p>
          </div>
          <a
            href={`/builders/claim/?builder=${builder.slug}&state=${stateSlug}`}
            class="btn btn-accent shrink-0"
          >
            Claim this listing →
          </a>
        </div>
      </section>
    )}

    {/* Nearby builders */}
    {nearbyBuilders.length > 0 && (
      <section class="mb-12">
        <h2 class="text-2xl mb-6">Nearby builders</h2>
        <div class="grid gap-4 grid-cols-1 sm:grid-cols-2">
          {nearbyBuilders.map((b) => (
            <BuilderCard
              name={b.name}
              slug={b.slug}
              state={b.state}
              city={b.city ?? undefined}
              tagline={b.tagline ?? undefined}
              platforms={b.platforms}
              priceTier={b.price_tier ?? undefined}
              description={b.description ?? undefined}
              logoUrl={b.logo_url ?? undefined}
              verified={b.verified}
              reviewRating={b.review_rating ?? undefined}
              reviewCount={b.review_count ?? undefined}
              website={b.website ?? undefined}
            />
          ))}
        </div>
      </section>
    )}

    {/* Cross-links */}
    <section class="pt-8 border-t" style="border-color: var(--color-border);">
      <h2 class="text-xl mb-4">Related</h2>
      <ul class="space-y-2 font-sans-ui text-sm">
        <li>
          <a href="/builders/add/">Add your shop to the directory (free)</a>
        </li>
        <li>
          <a href="/insurance/best-for-van-conversions/">Van conversion insurance: which carriers write these policies</a>
        </li>
        <li>
          <a href={`/registration/${stateToSlug(builder.state)}/`}>How to register a converted van in {builder.state}</a>
        </li>
        {builder.platforms.length > 0 && (
          <li>
            <a href={`/builders/platform/${platformSlug(builder.platforms[0])}/`}>
              All {builder.platforms[0]} builders in the directory
            </a>
          </li>
        )}
        <li>
          <a href={`/builders/${stateSlug}/`}>All builders in {builder.state}</a>
        </li>
        <li>
          <a href="/builders/">Full builder directory</a>
        </li>
      </ul>
    </section>
  </div>
</BaseLayout>

<script>
  const btn = document.getElementById("reveal-email-btn");
  if (btn) {
    btn.addEventListener("click", () => {
      const email = btn.getAttribute("data-email");
      if (email) {
        btn.textContent = email;
        btn.removeAttribute("data-email");
        btn.classList.remove("btn-ghost");
        btn.classList.add("btn-accent");
        btn.setAttribute("disabled", "true");
      }
    });
  }
</script>
