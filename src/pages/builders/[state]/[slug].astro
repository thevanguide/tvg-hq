---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../../components/Breadcrumbs.astro";
import BuilderCard from "../../../components/BuilderCard.astro";
import BuilderMap from "../../../components/BuilderMap";
import EditListingLink from "../../../components/EditListingLink";
import {
  getBuilderProfileShops,
  getNearbyBuilders,
  getShopProfileUrl,
  stateToSlug,
  toUrlSlug,
  type Builder,
} from "../../../lib/supabase";
import { profileMeta, localBusinessJsonLd } from "../../../lib/seo";
import { toRenderHtml } from "../../../lib/rich-text";
import { groupServices } from "../../../lib/taxonomy";

export async function getStaticPaths() {
  // Every shop tagged as a builder gets a /builders/[state]/[slug]/ profile.
  // Dual-tagged shops also get a /services/[state]/[slug]/ profile; the two
  // pages cross-link via the hero badge.
  const builders = await getBuilderProfileShops();
  return builders.map((b) => ({
    params: {
      state: stateToSlug(b.state),
      slug: b.slug,
    },
    props: { builder: b },
  }));
}

interface Props {
  builder: Builder;
}
const { builder } = Astro.props;

const meta = profileMeta(builder);
const siteUrl = Astro.site?.toString().replace(/\/$/, "") || "https://thevanguide.com";
const jsonLd = localBusinessJsonLd(builder, siteUrl, "builder");

const stateSlug = stateToSlug(builder.state);
const location = builder.city
  ? `${builder.city}, ${builder.state}`
  : builder.state;

// Nearby builders (2-4 within ~30 miles)
let nearbyBuilders: Awaited<ReturnType<typeof getNearbyBuilders>> = [];
if (builder.latitude != null && builder.longitude != null) {
  nearbyBuilders = (
    await getNearbyBuilders(builder.latitude, builder.longitude, 30, builder.id)
  ).slice(0, 4);
}

// Years in business
const currentYear = new Date().getFullYear();
const yearsInBusiness = builder.year_founded
  ? currentYear - builder.year_founded
  : null;

const breadcrumbs = [
  { label: "Home", href: "/" },
  { label: "Builders", href: "/builders/" },
  { label: builder.state, href: `/builders/${stateSlug}/` },
  { label: builder.name, href: `/builders/${stateSlug}/${builder.slug}/` },
];

// Star display helper
function renderStars(rating: number): string {
  const full = Math.floor(rating);
  const half = rating - full >= 0.25 && rating - full < 0.75;
  const empty = 5 - full - (half ? 1 : 0);
  return "★".repeat(full) + (half ? "½" : "") + "☆".repeat(empty);
}

function platformSlug(p: string): string {
  return toUrlSlug(p);
}

// P2 PR 1 — display labels for engagement_types and lead_time buckets.
const ENGAGEMENT_TYPE_LABELS: Record<string, string> = {
  new_build: "New builds",
  service_repair: "Service & repair",
  warranty_work: "Warranty work",
  rentals: "Rentals",
  parts_kits: "Parts / DIY kits",
};

const LEAD_TIME_LABELS: Record<string, string> = {
  under_1_month: "Under 1 month",
  "1_to_3_months": "1–3 months",
  "3_to_6_months": "3–6 months",
  "6_months_plus": "6+ months",
};

// P2 PR 2 — build style descriptions + filter hrefs. Legacy Custom/Standard
// values render nothing (owner-reclassification pending for 7 claimed rows).
const BUILD_STYLE_DESCRIPTIONS: Record<string, string> = {
  Bespoke: "One-of-one custom builds designed around each customer.",
  "Semi-custom": "Template floorplan with customer-chosen finishes and systems.",
  Production: "Fixed floorplans built to spec.",
};

const BUILD_STYLE_FILTER_PARAMS: Record<string, string> = {
  Bespoke: "bespoke",
  "Semi-custom": "semi-custom",
  Production: "production",
};

const isNewBuildStyle = builder.build_style != null && builder.build_style in BUILD_STYLE_DESCRIPTIONS;
---

<BaseLayout title={meta.title} description={meta.description}>
  <script is:inline type="application/ld+json" slot="head" set:html={JSON.stringify(jsonLd)} />

  {/* Breadcrumbs on the normal page background — always readable regardless
      of hero image content. */}
  <div class="container-wide pt-4">
    <Breadcrumbs items={breadcrumbs} />
  </div>

  {/* Hero banner — purely visual. The profile card below carries the text,
      so the banner is free to be any image without fighting for legibility.
      `?width=1600&quality=80` caps bandwidth via Supabase image transforms. */}
  <div
    class="h-48 md:h-96 border-b"
    style={
      builder.hero_image_url
        ? `border-color: var(--color-border); background: #1a1a1a url('${builder.hero_image_url}?width=1600&quality=80') center/cover no-repeat;`
        : "border-color: var(--color-border); background: linear-gradient(135deg, var(--color-surface) 0%, var(--color-bg-alt) 100%);"
    }
    aria-hidden="true"
  />

  {/* Profile card — LinkedIn-style, overlaps the bottom of the hero banner.
      Everything that matters (name, tagline, metadata, CTAs) lives on white so
      it stays legible no matter what the banner looks like. */}
  <section class="container-wide relative -mt-12 md:-mt-20 mb-8 md:mb-12">
    <div
      class="bg-white border rounded-lg p-5 md:p-8"
      style="border-color: var(--color-border); box-shadow: 0 4px 16px rgba(0,0,0,0.06);"
    >
      <div class="flex flex-col md:flex-row md:items-start gap-4 md:gap-6">
        {/* Logo — lifted off the card with its own border + shadow so it reads
            as a distinct element, like a profile photo. */}
        {builder.logo_url ? (
          <img
            src={builder.logo_url}
            alt={`${builder.name} logo`}
            class="w-20 h-20 md:w-24 md:h-24 object-contain rounded-lg shrink-0 p-2 border self-start"
            style="background: #2a2a2a; border-color: var(--color-border); box-shadow: 0 2px 8px rgba(0,0,0,0.08);"
            width="96"
            height="96"
          />
        ) : (
          <div
            class="w-20 h-20 md:w-24 md:h-24 flex items-center justify-center rounded-lg shrink-0 border self-start"
            style="background: var(--color-bg-alt); border-color: var(--color-border);"
          >
            <img src="/images/van-icon.svg" alt="" class="w-12 h-12 md:w-14 md:h-14 opacity-30" width="56" height="56" />
          </div>
        )}

        <div class="flex-1 min-w-0">
          {/* Dual-directory eyebrow — sits above the name on dual-tagged
              shops so viewers can jump to the repair & service profile
              without the link competing with primary CTAs. */}
          {builder.categories?.includes("service") && (
            <a
              href={`/services/${stateSlug}/${builder.slug}/`}
              class="eyebrow text-xs no-underline hover:underline inline-block mb-2"
            >
              View repair &amp; service profile →
            </a>
          )}
          <div class="flex items-center gap-3 flex-wrap">
            <h1 class="text-3xl md:text-4xl leading-tight">{builder.name}</h1>
            {builder.verified && (
              <span
                class="text-xs font-sans-ui uppercase tracking-wider px-2 py-1 rounded shrink-0"
                style="background: var(--color-primary); color: var(--color-bg);"
                title="This listing is owner-verified"
              >
                Verified
              </span>
            )}
          </div>

          {builder.tagline && (
            <p class="mt-2 text-lg" style="color: var(--color-text-muted);">
              {builder.tagline}
            </p>
          )}

          <div class="mt-2 font-sans-ui text-sm" style="color: var(--color-text-muted);">
            {location}
          </div>

          {/* CTAs — primary actions on the left, social links pushed to the
              right edge (or wrap below on mobile). Socials are muted/borderless
              so they don't compete with the primary buttons. */}
          <div class="mt-5 flex flex-wrap items-center gap-2 sm:gap-3">
            {builder.website && (
              <a
                href={builder.website}
                class="btn btn-primary"
                target="_blank"
                rel="noopener noreferrer"
              >
                Visit Website
              </a>
            )}
            {builder.phone && (
              <a href={`tel:${builder.phone}`} class="btn btn-ghost">
                Call {builder.phone}
              </a>
            )}
            {builder.emails && builder.emails.length > 0 && (
              <button
                class="btn btn-ghost"
                data-email={builder.emails[0]}
                id="reveal-email-btn"
                type="button"
              >
                Email
              </button>
            )}
            {(builder.instagram_handle || builder.youtube_url) && (
              <div class="flex items-center gap-1 sm:ml-auto">
                {builder.instagram_handle && (
                  <a
                    href={`https://instagram.com/${builder.instagram_handle}`}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center justify-center w-8 h-8 rounded-full transition-colors hover:bg-[var(--color-bg-alt)]"
                    style="color: var(--color-text-muted);"
                    aria-label={`${builder.name} on Instagram`}
                    title="Instagram"
                  >
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
                      <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
                      <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
                    </svg>
                  </a>
                )}
                {builder.youtube_url && (
                  <a
                    href={builder.youtube_url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center justify-center w-8 h-8 rounded-full transition-colors hover:bg-[var(--color-bg-alt)]"
                    style="color: var(--color-text-muted);"
                    aria-label={`${builder.name} on YouTube`}
                    title="YouTube"
                  >
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                      <path d="M23.5 6.5a3 3 0 0 0-2.1-2.1C19.4 4 12 4 12 4s-7.4 0-9.4.4A3 3 0 0 0 .5 6.5 31 31 0 0 0 0 12a31 31 0 0 0 .5 5.5 3 3 0 0 0 2.1 2.1C4.6 20 12 20 12 20s7.4 0 9.4-.4a3 3 0 0 0 2.1-2.1A31 31 0 0 0 24 12a31 31 0 0 0-.5-5.5zM9.6 15.6v-7.2L15.8 12l-6.2 3.6z"></path>
                    </svg>
                  </a>
                )}
              </div>
            )}
          </div>

          {/* Owner-only edit link (renders nothing if not the owner) */}
          <EditListingLink client:idle builderId={builder.id} />
        </div>
      </div>
    </div>
  </section>

  {/* Quick overview — spec-sheet style summary below the hero card. Each
      fact is a label/value pair so it reads cleaner than a row of pills.
      Only renders if the shop has at least one fact worth showing. */}
  {(
    builder.platforms.length > 0 ||
    builder.starting_price != null ||
    (builder.price_tier && builder.price_tier !== "Unknown") ||
    (builder.conversion_types && builder.conversion_types.length > 0) ||
    (builder.engagement_types && builder.engagement_types.length > 0) ||
    isNewBuildStyle ||
    builder.lead_time ||
    builder.warranty_months != null ||
    (yearsInBusiness != null && yearsInBusiness >= 5)
  ) && (
    <section class="container-wide mb-8 md:mb-12">
      <div
        class="bg-white border rounded-lg px-5 md:px-8 py-4 md:py-5 grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-x-6 gap-y-4"
        style="border-color: var(--color-border);"
      >
        {builder.platforms.length > 0 && (
          <div>
            <div class="eyebrow text-xs mb-1">Platforms</div>
            <div class="font-sans-ui text-sm leading-snug">
              {builder.platforms.map((p, i) => (<Fragment><Fragment set:html={i > 0 ? ", " : ""} /><a href={`/builders/platform/${platformSlug(p)}/`} class="no-underline hover:underline" style="color: var(--color-text);">{p}</a></Fragment>))}
            </div>
          </div>
        )}
        {builder.starting_price != null && (
          <div>
            <div class="eyebrow text-xs mb-1">Starts at</div>
            <div class="font-sans-ui text-sm font-semibold" style="color: var(--color-text);">
              ${builder.starting_price.toLocaleString("en-US")}
            </div>
          </div>
        )}
        {/* Tier shown only when a concrete starting_price isn't set — same
            suppression rule as the original pill. */}
        {builder.starting_price == null && builder.price_tier && builder.price_tier !== "Unknown" && (
          <div>
            <div class="eyebrow text-xs mb-1">Price range</div>
            <a
              href={`/builders/tier/${builder.price_tier.toLowerCase()}/`}
              class="font-sans-ui text-sm no-underline hover:underline"
              style="color: var(--color-text);"
            >
              {builder.price_tier === "Budget" ? "$ Budget" : builder.price_tier === "Mid" ? "$$ Mid-range" : builder.price_tier === "Premium" ? "$$$ Premium" : builder.price_tier === "Luxury" ? "$$$$ Luxury" : builder.price_tier}
            </a>
          </div>
        )}
        {builder.conversion_types && builder.conversion_types.length > 0 && (
          <div>
            <div class="eyebrow text-xs mb-1">Offers</div>
            <div class="font-sans-ui text-sm" style="color: var(--color-text);">
              {[
                builder.conversion_types.includes("full_build") ? "Turnkey builds" : null,
                builder.conversion_types.includes("conversion_only") ? "Conversion only" : null,
              ]
                .filter(Boolean)
                .join(", ")}
            </div>
          </div>
        )}
        {builder.engagement_types && builder.engagement_types.length > 0 && (
          <div>
            <div class="eyebrow text-xs mb-1">Work offered</div>
            <div class="font-sans-ui text-sm" style="color: var(--color-text);">
              {builder.engagement_types
                .map((t) => ENGAGEMENT_TYPE_LABELS[t])
                .filter(Boolean)
                .join(", ")}
            </div>
          </div>
        )}
        {isNewBuildStyle && builder.build_style && (
          <div>
            <div class="eyebrow text-xs mb-1">Build style</div>
            <a
              href={`/builders/?style=${BUILD_STYLE_FILTER_PARAMS[builder.build_style]}`}
              class="font-sans-ui text-sm no-underline hover:underline"
              style="color: var(--color-text);"
              title={BUILD_STYLE_DESCRIPTIONS[builder.build_style]}
            >
              {builder.build_style}
            </a>
            <div
              class="font-sans-ui text-xs mt-0.5"
              style="color: var(--color-text-muted);"
            >
              {BUILD_STYLE_DESCRIPTIONS[builder.build_style]}
            </div>
          </div>
        )}
        {builder.lead_time && LEAD_TIME_LABELS[builder.lead_time] && (
          <div>
            <div class="eyebrow text-xs mb-1">Lead time</div>
            <div class="font-sans-ui text-sm" style="color: var(--color-text);">
              {LEAD_TIME_LABELS[builder.lead_time]}
            </div>
          </div>
        )}
        {builder.warranty_months != null && (
          <div>
            <div class="eyebrow text-xs mb-1">Warranty</div>
            <div class="font-sans-ui text-sm" style="color: var(--color-text);">
              {builder.warranty_months === 0
                ? "None"
                : builder.warranty_months >= 12 && builder.warranty_months % 12 === 0
                  ? `${builder.warranty_months / 12} ${builder.warranty_months === 12 ? "year" : "years"}`
                  : `${builder.warranty_months} months`}
            </div>
          </div>
        )}
        {yearsInBusiness != null && yearsInBusiness >= 5 && (
          <div>
            <div class="eyebrow text-xs mb-1">In business</div>
            <div class="font-sans-ui text-sm" style="color: var(--color-text);">
              {yearsInBusiness}+ years
            </div>
          </div>
        )}
      </div>
    </section>
  )}

  {/* Claim banner — right below hero, above content */}
  {!builder.claimed && (
    <div style="background: var(--color-bg-alt); border-bottom: 1px solid var(--color-border);">
      <div class="container-wide py-3 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 sm:gap-4 max-w-4xl">
        <p class="font-sans-ui text-sm" style="color: var(--color-text-muted);">
          <strong style="color: var(--color-text);">Is this your business?</strong> Claim this listing to add photos, update your info, and get a verified badge.
        </p>
        <a
          href={`/builders/claim/?builder=${builder.slug}&state=${stateSlug}`}
          class="btn btn-accent text-sm shrink-0"
        >
          Claim this listing
        </a>
      </div>
    </div>
  )}

  {/* Owner disclosure — ECB only */}
  {builder.slug === "emery-custom-builds" && (
    <div style="background: var(--color-bg-alt); border-bottom: 1px solid var(--color-border);">
      <div class="container-wide py-3 max-w-4xl">
        <p class="font-sans-ui text-sm" style="color: var(--color-text-muted);">
          <strong style="color: var(--color-text);">Disclosure:</strong> This shop is operated by the founder of The Van Guide. It is listed under the same criteria as every other builder and receives no preferential placement.
          <a href="/builders/how-we-review/#conflicts-of-interest" class="ml-1">Learn more →</a>
        </p>
      </div>
    </div>
  )}

  <div class="container-wide py-12 md:py-16 max-w-4xl">
    {/* About section. `description` may be legacy plain text or HTML emitted
        by the dashboard rich-text editor; toRenderHtml sanitizes + wraps
        plain text in <p> so the prose container styles both consistently. */}
    {builder.description && (
      <section class="mb-12">
        <h2 class="text-2xl mb-4">About {builder.name}</h2>
        <div class="prose" set:html={toRenderHtml(builder.description)} />
        {builder.year_founded && (
          <p class="mt-4 font-sans-ui text-sm" style="color: var(--color-text-muted);">
            Established {builder.year_founded}
          </p>
        )}
      </section>
    )}

    {/* Gallery — only show if photos exist */}
    {builder.gallery_urls && builder.gallery_urls.length > 0 && (
      <section class="mb-12">
        <div class="grid gap-3 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
          {builder.gallery_urls.map((url, i) => (
            <img
              src={url}
              alt={`${builder.name} build photo ${i + 1}`}
              class="w-full aspect-[4/3] object-cover rounded-lg"
              style="background: var(--color-bg-alt);"
              width="600"
              height="450"
              loading={i === 0 ? "eager" : "lazy"}
            />
          ))}
        </div>
      </section>
    )}

    {/* Services & platforms */}
    {(builder.services.length > 0 || builder.platforms.length > 0) && (
      <section class="mb-12">
        <h2 class="text-2xl mb-4">Services &amp; platforms</h2>
        <div class="grid sm:grid-cols-2 gap-6">
          {builder.platforms.length > 0 && (
            <div>
              <div class="eyebrow mb-3">Platforms</div>
              <div class="flex flex-wrap gap-2">
                {builder.platforms.map((p) => (
                  <a
                    href={`/builders/platform/${platformSlug(p)}/`}
                    class="text-sm font-sans-ui px-3 py-1.5 rounded-full border no-underline transition-colors hover:border-current"
                    style="border-color: var(--color-border-strong); color: var(--color-text);"
                  >
                    {p}
                  </a>
                ))}
              </div>
            </div>
          )}
          {builder.services.length > 0 && (
            <div>
              <div class="eyebrow mb-3">Services</div>
              <div class="space-y-4">
                {groupServices(builder.services).map((group) => (
                  <div>
                    <div
                      class="font-sans-ui text-xs uppercase tracking-wider mb-2"
                      style="color: var(--color-text-subtle, #888);"
                    >
                      {group.label}
                    </div>
                    <div class="flex flex-wrap gap-2">
                      {group.services.map((s) => {
                        const serviceSlug = toUrlSlug(s);
                        return (
                          <a
                            href={`/builders/service/${serviceSlug}/`}
                            class="text-sm font-sans-ui px-3 py-1.5 rounded-full border no-underline transition-colors hover:border-current"
                            style="border-color: var(--color-border-strong); color: var(--color-text);"
                          >
                            {s}
                          </a>
                        );
                      })}
                    </div>
                  </div>
                ))}
              </div>
            </div>
          )}
        </div>
      </section>
    )}

    {/* Pricing section */}
    {builder.price_tier && (
      <section class="mb-12">
        <h2 class="text-2xl mb-4">Pricing</h2>
        <p class="font-sans-ui">
          Based on publicly available information, this builder falls in the <strong>{builder.price_tier === "Budget" ? "budget" : builder.price_tier === "Mid" ? "mid-range" : builder.price_tier === "Premium" ? "premium" : builder.price_tier === "Luxury" ? "luxury" : builder.price_tier?.toLowerCase()}</strong> price range.
        </p>
        {builder.price_evidence && (
          <p class="mt-2 text-sm" style="color: var(--color-text-muted);">
            {builder.price_evidence}
          </p>
        )}
        <p class="mt-3 text-sm" style="color: var(--color-text-muted);">
          Pricing varies by platform, layout, and options. Contact this builder directly for an accurate quote.
        </p>
      </section>
    )}

    {/* Reviews & reputation */}
    {builder.review_rating != null && builder.review_rating > 0 && (
      <section class="mb-12">
        <h2 class="text-2xl mb-4">Reviews</h2>
        <div class="flex items-center gap-3 font-sans-ui">
          <span class="text-2xl md:text-3xl" style="color: var(--color-accent);">
            {renderStars(builder.review_rating)}
          </span>
          <div>
            <div class="text-lg font-semibold">{builder.review_rating.toFixed(1)} / 5</div>
            {builder.review_count != null && builder.review_count > 0 && (
              <div class="text-sm" style="color: var(--color-text-muted);">
                Based on {builder.review_count} Google {builder.review_count === 1 ? "review" : "reviews"}
              </div>
            )}
          </div>
        </div>
        {builder.google_maps_url && (
          <a
            href={builder.google_maps_url}
            class="inline-block mt-3 font-sans-ui text-sm"
            target="_blank"
            rel="noopener noreferrer"
          >
            View on Google Maps →
          </a>
        )}
      </section>
    )}

    {/* Location */}
    <section class="mb-12">
      <h2 class="text-2xl mb-4">Location</h2>
      {builder.latitude != null && builder.longitude != null && (
        <div class="mb-4">
          <BuilderMap
            client:visible
            builders={[{
              id: builder.id,
              name: builder.name,
              slug: builder.slug,
              state: builder.state,
              city: builder.city,
              latitude: builder.latitude,
              longitude: builder.longitude,
              review_rating: builder.review_rating,
              review_count: builder.review_count,
              profile_href: `/builders/${stateSlug}/${builder.slug}/`,
            }]}
            singlePin={true}
            center={[builder.latitude, builder.longitude]}
            zoom={13}
          />
        </div>
      )}
      <p class="font-sans-ui">
        {builder.street && <span>{builder.street}<br /></span>}
        {location}
        {builder.postal_code && ` ${builder.postal_code}`}
      </p>
      {builder.google_maps_url && (
        <a
          href={builder.google_maps_url}
          class="inline-block mt-3 font-sans-ui text-sm"
          target="_blank"
          rel="noopener noreferrer"
        >
          Open in Google Maps →
        </a>
      )}
    </section>

    {/* Claim listing CTA — above nearby builders */}
    {!builder.claimed && (
      <section class="mb-12 p-5 sm:p-8 border" style="border-color: var(--color-primary); border-radius: var(--radius-lg); background: var(--color-surface);">
        <div class="flex flex-col sm:flex-row sm:items-center gap-4 sm:gap-6">
          <div class="flex-1">
            <h3 class="text-xl sm:text-2xl mb-2">Is this your business?</h3>
            <p class="font-sans-ui text-sm" style="color: var(--color-text-muted);">
              Claim this listing to add photos, update your description, and display a verified badge. Free during launch.
            </p>
          </div>
          <a
            href={`/builders/claim/?builder=${builder.slug}&state=${stateSlug}`}
            class="btn btn-accent shrink-0"
          >
            Claim this listing →
          </a>
        </div>
      </section>
    )}

    {/* Nearby builders */}
    {nearbyBuilders.length > 0 && (
      <section class="mb-12">
        <h2 class="text-2xl mb-6">Nearby builders</h2>
        <div class="grid gap-4 grid-cols-1 sm:grid-cols-2">
          {nearbyBuilders.map((b) => (
            <BuilderCard
              name={b.name}
              slug={b.slug}
              state={b.state}
              city={b.city ?? undefined}
              tagline={b.tagline ?? undefined}
              platforms={b.platforms}
              priceTier={b.price_tier ?? undefined}
              description={b.description ?? undefined}
              logoUrl={b.logo_url ?? undefined}
              verified={b.verified}
              reviewRating={b.review_rating ?? undefined}
              reviewCount={b.review_count ?? undefined}
              website={b.website ?? undefined}
              profileHref={getShopProfileUrl(b, "/builders")}
            />
          ))}
        </div>
      </section>
    )}

    {/* Cross-links */}
    <section class="pt-8 border-t" style="border-color: var(--color-border);">
      <h2 class="text-xl mb-4">Related</h2>
      <ul class="space-y-2 font-sans-ui text-sm">
        <li>
          <a href="/builders/add/">Add your shop to the directory (free)</a>
        </li>
        <li>
          <a href="/insurance/best-for-van-conversions/">Van conversion insurance: which carriers write these policies</a>
        </li>
        <li>
          <a href={`/registration/${stateToSlug(builder.state)}/`}>How to register a converted van in {builder.state}</a>
        </li>
        {builder.platforms.length > 0 && (
          <li>
            <a href={`/builders/platform/${platformSlug(builder.platforms[0])}/`}>
              All {builder.platforms[0]} builders in the directory
            </a>
          </li>
        )}
        <li>
          <a href={`/builders/${stateSlug}/`}>All builders in {builder.state}</a>
        </li>
        <li>
          <a href="/builders/">Full builder directory</a>
        </li>
      </ul>
    </section>
  </div>
</BaseLayout>

<script>
  const btn = document.getElementById("reveal-email-btn");
  if (btn) {
    btn.addEventListener("click", () => {
      const email = btn.getAttribute("data-email");
      if (email) {
        btn.textContent = email;
        btn.removeAttribute("data-email");
        btn.classList.remove("btn-ghost");
        btn.classList.add("btn-accent");
        btn.setAttribute("disabled", "true");
      }
    });
  }
</script>
