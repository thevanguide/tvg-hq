---
import DirectoryLayout from "../../../layouts/DirectoryLayout.astro";
import BuilderSearch from "../../../components/BuilderSearch";
import {
  getAllBuilders,
  getDistinctCities,
  stateToSlug,
  cityToSlug,
} from "../../../lib/supabase";
import { stateMeta } from "../../../lib/seo";

export async function getStaticPaths() {
  const builders = await getAllBuilders();
  const states = new Set(builders.map((b) => b.state));

  // Seed a handful of states so the route exists even with an empty database
  const seed = [
    "California", "Colorado", "Oregon", "Utah", "Arizona",
    "Texas", "Washington", "Florida", "North Carolina",
  ];
  seed.forEach((s) => states.add(s));

  return [...states].map((state) => ({
    params: { state: stateToSlug(state) },
    props: { stateName: state },
  }));
}

interface Props {
  stateName: string;
}
const { stateName } = Astro.props;

const all = await getAllBuilders();
const builders = all.filter(
  (b) => b.state.toLowerCase() === stateName.toLowerCase(),
);

const cities = await getDistinctCities(stateName);
const meta = stateMeta(stateName, builders.length);

const breadcrumbs = [
  { label: "Home", href: "/" },
  { label: "Builders", href: "/builders/" },
  { label: stateName, href: `/builders/${stateToSlug(stateName)}/` },
];

const stateSlug = stateToSlug(stateName);

// Serialize builder data for the React search island (includes lat/lng for map)
const searchData = builders.map((b) => ({
  id: b.id,
  name: b.name,
  slug: b.slug,
  state: b.state,
  city: b.city,
  tagline: b.tagline,
  platforms: b.platforms,
  services: b.services,
  price_tier: b.price_tier,
  description: b.description,
  logo_url: b.logo_url,
  verified: b.verified,
  review_rating: b.review_rating,
  review_count: b.review_count,
  website: b.website,
  year_founded: b.year_founded,
  build_style: b.build_style,
  latitude: b.latitude,
  longitude: b.longitude,
}));
---

<DirectoryLayout
  title={meta.title}
  description={meta.description}
  eyebrow="Directory"
  heading={`Van Conversion Builders in ${stateName}`}
  intro={builders.length > 0
    ? `${builders.length} van conversion ${builders.length === 1 ? "shop" : "shops"} in ${stateName}. Browse by city, compare platforms and pricing, and find the right builder for your project.`
    : `We're building out the ${stateName} directory. Check back soon.`}
  breadcrumbs={breadcrumbs}
>
  {builders.length === 0 ? (
    <div
      class="p-10 text-center border border-dashed"
      style="border-color: var(--color-border-strong); border-radius: var(--radius-lg); background: var(--color-surface);"
    >
      <h2 class="text-xl mb-2">No listings yet</h2>
      <p style="color: var(--color-text-muted);">
        We're still adding {stateName} builders to the directory. Check back soon.
      </p>
    </div>
  ) : (
    <>
      {/* City quick-links */}
      {cities.length > 1 && (
        <section class="mb-10">
          <div class="eyebrow mb-4">Cities</div>
          <div class="flex flex-wrap gap-2">
            {cities.map(({ city, count }) => (
              <a
                href={`/builders/${stateSlug}/${cityToSlug(city)}/`}
                class="px-3 py-1.5 font-sans-ui text-sm border no-underline transition-colors hover:border-current"
                style="border-color: var(--color-border-strong); border-radius: 999px; color: var(--color-text);"
              >
                {city} <span style="color: var(--color-text-subtle);">({count})</span>
              </a>
            ))}
          </div>
        </section>
      )}

      {/* Unified search + map island */}
      <BuilderSearch client:idle builders={searchData} />
    </>
  )}

  {/* Cross-links */}
  <nav class="mt-12 pt-8 border-t font-sans-ui text-sm flex flex-wrap gap-x-6 gap-y-2" style="border-color: var(--color-border);">
    <a href="/builders/">← All states</a>
    <a href="/builders/platform/sprinter/">Sprinter builders</a>
    <a href="/builders/platform/promaster/">ProMaster builders</a>
    <a href="/insurance/best-for-van-conversions/">Van conversion insurance</a>
  </nav>
</DirectoryLayout>
