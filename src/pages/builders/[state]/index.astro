---
import DirectoryLayout from "../../../layouts/DirectoryLayout.astro";
import BuilderSearch from "../../../components/BuilderSearch";
import {
  getAllBuilders,
  getDistinctCities,
  getShopProfileUrl,
  stateToSlug,
  cityToSlug,
} from "../../../lib/supabase";
import { stateMeta, itemListJsonLd, faqPageJsonLd } from "../../../lib/seo";

export async function getStaticPaths() {
  const builders = await getAllBuilders();
  const states = new Set(builders.map((b) => b.state));

  // Seed a handful of states so the route exists even with an empty database
  const seed = [
    "California", "Colorado", "Oregon", "Utah", "Arizona",
    "Texas", "Washington", "Florida", "North Carolina",
  ];
  seed.forEach((s) => states.add(s));

  return [...states].map((state) => ({
    params: { state: stateToSlug(state) },
    props: { stateName: state },
  }));
}

interface Props {
  stateName: string;
}
const { stateName } = Astro.props;

const all = await getAllBuilders();
const builders = all.filter(
  (b) => b.state.toLowerCase() === stateName.toLowerCase(),
);

const cities = await getDistinctCities(stateName);
const meta = stateMeta(stateName, builders.length);

const breadcrumbs = [
  { label: "Home", href: "/" },
  { label: "Builders", href: "/builders/" },
  { label: stateName, href: `/builders/${stateToSlug(stateName)}/` },
];

const stateSlug = stateToSlug(stateName);

// --- AEO: Compute stats for answerable content & FAQ schema ---
const platformCounts = new Map<string, number>();
const tierCounts = new Map<string, number>();
for (const b of builders) {
  if (b.platforms) {
    for (const p of b.platforms) {
      platformCounts.set(p, (platformCounts.get(p) ?? 0) + 1);
    }
  }
  if (b.price_tier) {
    tierCounts.set(b.price_tier, (tierCounts.get(b.price_tier) ?? 0) + 1);
  }
}
const topPlatforms = [...platformCounts.entries()]
  .sort((a, b) => b[1] - a[1])
  .slice(0, 3)
  .map(([name]) => name);
const tierLabels: Record<string, string> = {
  budget: "budget ($15k–$30k)",
  mid: "mid-range ($30k–$80k)",
  premium: "premium ($80k–$150k+)",
  luxury: "luxury ($150k+)",
};
const tierList = [...tierCounts.entries()]
  .sort((a, b) => b[1] - a[1])
  .filter(([t]) => t in tierLabels)
  .map(([t]) => tierLabels[t]);

const platformSentence = topPlatforms.length > 0
  ? `The most common platforms are ${topPlatforms.join(", ")}.`
  : "";
const tierSentence = tierList.length > 0
  ? `Builders in ${stateName} span ${tierList.join(", ")} price ranges.`
  : "";

// FAQ items for structured data
const faqs = builders.length > 0
  ? [
      {
        question: `How many van builders are in ${stateName}?`,
        answer: `The Van Guide lists ${builders.length} van conversion ${builders.length === 1 ? "company" : "companies"} in ${stateName}. The directory is updated regularly as new builders are verified.`,
      },
      ...(topPlatforms.length > 0
        ? [{
            question: `What van platforms do ${stateName} builders work on?`,
            answer: `The most popular platforms among ${stateName} van builders are ${topPlatforms.join(", ")}. Many shops work on multiple platforms — use the directory filters to find builders for your specific van.`,
          }]
        : []),
      ...(tierList.length > 0
        ? [{
            question: `How much does a van conversion cost in ${stateName}?`,
            answer: `Van conversion pricing in ${stateName} varies by builder and scope. ${tierSentence} Costs depend on the base vehicle, layout complexity, electrical system, and materials. Contact builders directly for project-specific quotes.`,
          }]
        : []),
      {
        question: `How do I choose a van builder in ${stateName}?`,
        answer: `Start by narrowing your search to builders that work on your platform (Sprinter, ProMaster, or Transit) and fit your budget. Review their portfolio, check Google reviews, ask about warranties and build timelines, and visit the shop if possible. The Van Guide profiles include ratings, services, and direct contact info to help you compare.`,
      },
    ]
  : [];

// Serialize builder data for the React search island (includes lat/lng for map)
const searchData = builders.map((b) => ({
  id: b.id,
  name: b.name,
  slug: b.slug,
  state: b.state,
  city: b.city,
  tagline: b.tagline,
  platforms: b.platforms,
  services: b.services,
  price_tier: b.price_tier,
  description: b.description,
  logo_url: b.logo_url,
  verified: b.verified,
  review_rating: b.review_rating,
  review_count: b.review_count,
  website: b.website,
  year_founded: b.year_founded,
  build_style: b.build_style,
  latitude: b.latitude,
  longitude: b.longitude,
  profile_href: getShopProfileUrl(b, "/builders"),
}));
---

<DirectoryLayout
  title={meta.title}
  description={meta.description}
  eyebrow="Directory"
  heading={`Van Conversion Builders in ${stateName}`}
  intro={builders.length > 0
    ? `${builders.length} van conversion ${builders.length === 1 ? "shop" : "shops"} in ${stateName}. Browse by city, compare platforms and pricing, and find the right builder for your project.`
    : `We're building out the ${stateName} directory. Check back soon.`}
  breadcrumbs={breadcrumbs}
>
  {/* Answerable content block for AI citation */}
  {builders.length > 0 && (
    <section class="mb-10 prose max-w-none">
      <p>
        {stateName} is home to {builders.length} van conversion {builders.length === 1 ? "company" : "companies"} listed
        in The Van Guide directory.{" "}
        {platformSentence}{" "}
        {tierSentence}
      </p>
      <p>
        Each builder profile includes services offered, pricing tier, Google review ratings, and direct contact
        information. Use the search and map below to find shops near you, or browse by city to narrow your options.
      </p>
    </section>
  )}

  {builders.length === 0 ? (
    <div
      class="p-10 text-center border border-dashed"
      style="border-color: var(--color-border-strong); border-radius: var(--radius-lg); background: var(--color-surface);"
    >
      <h2 class="text-xl mb-2">No listings yet</h2>
      <p style="color: var(--color-text-muted);">
        We're still adding {stateName} builders to the directory. Check back soon.
      </p>
    </div>
  ) : (
    <>
      {/* City quick-links */}
      {cities.length > 1 && (
        <section class="mb-10">
          <div class="eyebrow mb-4">Cities</div>
          <div class="flex flex-wrap gap-2">
            {cities.map(({ city, count }) => (
              <a
                href={`/builders/${stateSlug}/${cityToSlug(city)}/`}
                class="px-3 py-1.5 font-sans-ui text-sm border no-underline transition-colors hover:border-current"
                style="border-color: var(--color-border-strong); border-radius: 999px; color: var(--color-text);"
              >
                {city} <span style="color: var(--color-text-subtle);">({count})</span>
              </a>
            ))}
          </div>
        </section>
      )}

      {/* Unified search + map island */}
      <BuilderSearch client:idle builders={searchData} />
    </>
  )}

  {/* Builder CTA */}
  <section
    class="mt-12 p-6 border flex flex-col sm:flex-row sm:items-center gap-4"
    style="border-color: var(--color-primary); border-radius: var(--radius-lg); background: var(--color-surface);"
  >
    <div class="flex-1">
      <div class="eyebrow mb-2">For builders</div>
      <p class="font-sans-ui text-sm" style="color: var(--color-text-muted);">
        Own a van conversion shop in {stateName}? Get listed in the directory for free.
      </p>
    </div>
    <div class="flex gap-2 shrink-0">
      <a href="/builders/claim/" class="btn btn-accent text-sm">Claim listing</a>
      <a href="/builders/add/" class="btn btn-ghost text-sm">Add shop</a>
    </div>
  </section>

  {/* FAQ section — visible content for AEO */}
  {faqs.length > 0 && (
    <section class="mt-12 mb-8">
      <h2 class="text-2xl mb-6">Frequently asked questions</h2>
      <dl class="space-y-6">
        {faqs.map((faq) => (
          <div>
            <dt class="font-sans-ui font-semibold text-lg mb-2">{faq.question}</dt>
            <dd style="color: var(--color-text-muted);">{faq.answer}</dd>
          </div>
        ))}
      </dl>
    </section>
  )}

  {/* Cross-links */}
  <nav class="mt-8 pt-8 border-t font-sans-ui text-sm flex flex-wrap gap-x-6 gap-y-2" style="border-color: var(--color-border);">
    <a href="/builders/">← All states</a>
    <a href="/builders/platform/sprinter/">Sprinter builders</a>
    <a href="/builders/platform/promaster/">ProMaster builders</a>
    <a href="/insurance/best-for-van-conversions/">Van conversion insurance</a>
  </nav>

  {/* ItemList structured data */}
  {builders.length > 0 && (
    <script type="application/ld+json" set:html={JSON.stringify(itemListJsonLd(builders, `Van Conversion Builders in ${stateName}`))} />
  )}

  {/* FAQPage structured data */}
  {faqs.length > 0 && (
    <script type="application/ld+json" set:html={JSON.stringify(faqPageJsonLd(faqs))} />
  )}
</DirectoryLayout>
