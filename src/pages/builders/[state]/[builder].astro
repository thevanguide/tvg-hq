---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getAllBuilders, type Builder } from "../../../lib/supabase";

export async function getStaticPaths() {
  const builders = await getAllBuilders();
  return builders.map((b) => ({
    params: {
      state: b.state.toLowerCase().replace(/\s+/g, "-"),
      builder: b.slug,
    },
    props: { builder: b },
  }));
}

interface Props {
  builder: Builder;
}
const { builder } = Astro.props;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  name: builder.name,
  url: builder.website ?? undefined,
  description: builder.description ?? undefined,
  image: builder.logo_url ?? undefined,
  address: {
    "@type": "PostalAddress",
    addressRegion: builder.state,
    addressLocality: builder.city ?? undefined,
    addressCountry: "US",
  },
};
---

<BaseLayout
  title={`${builder.name} — Van Builder`}
  description={builder.description ?? `${builder.name}, a van conversion shop in ${builder.state}.`}
>
  <script is:inline type="application/ld+json" slot="head" set:html={JSON.stringify(jsonLd)} />
  <article class="container-wide py-14 md:py-20 max-w-4xl">
    <a href="/builders/" class="font-sans-ui text-sm">← All builders</a>
    <header class="mt-6 mb-10">
      <div class="eyebrow mb-3">{builder.city ? `${builder.city}, ${builder.state}` : builder.state}</div>
      <h1 class="text-4xl md:text-5xl leading-tight">{builder.name}</h1>
      {builder.description && (
        <p class="mt-5 text-lg leading-relaxed max-w-2xl" style="color: var(--color-text-muted);">
          {builder.description}
        </p>
      )}
      {builder.website && (
        <div class="mt-6">
          <a href={builder.website} class="btn btn-primary" target="_blank" rel="noopener nofollow">
            Visit website →
          </a>
        </div>
      )}
    </header>
    <div class="grid md:grid-cols-3 gap-8 font-sans-ui text-sm">
      {builder.platforms.length > 0 && (
        <div>
          <div class="eyebrow mb-2">Platforms</div>
          <ul class="space-y-1">
            {builder.platforms.map((p) => <li>{p}</li>)}
          </ul>
        </div>
      )}
      {builder.services.length > 0 && (
        <div>
          <div class="eyebrow mb-2">Services</div>
          <ul class="space-y-1">
            {builder.services.map((s) => <li>{s}</li>)}
          </ul>
        </div>
      )}
      {(builder.price_tier || builder.year_founded) && (
        <div>
          {builder.price_tier && (
            <>
              <div class="eyebrow mb-2">Price tier</div>
              <div class="mb-4">{builder.price_tier}</div>
            </>
          )}
          {builder.year_founded && (
            <>
              <div class="eyebrow mb-2">Founded</div>
              <div>{builder.year_founded}</div>
            </>
          )}
        </div>
      )}
    </div>
  </article>
</BaseLayout>
