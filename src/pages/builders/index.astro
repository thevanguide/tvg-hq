---
import DirectoryLayout from "../../layouts/DirectoryLayout.astro";
import BuilderSearch from "../../components/BuilderSearch";
import {
  getAllBuilders,
  getDistinctStates,
  getShopProfileUrl,
  stateToSlug,
} from "../../lib/supabase";
import { itemListJsonLd, faqPageJsonLd } from "../../lib/seo";

const builders = await getAllBuilders();
const states = await getDistinctStates();

// State counts for quick-links
const stateCounts = new Map<string, number>();
for (const b of builders) {
  stateCounts.set(b.state, (stateCounts.get(b.state) ?? 0) + 1);
}
const stateEntries = [...stateCounts.entries()].sort((a, b) => a[0].localeCompare(b[0]));

const builderCount = builders.length;
const stateCount = states.length;

const breadcrumbs = [
  { label: "Home", href: "/" },
  { label: "Builders", href: "/builders/" },
];

// FAQ items for structured data + visible section
const hubFaqs = builderCount > 0
  ? [
      {
        question: "How do I choose a van conversion builder?",
        answer: `Start by deciding on your van platform (Sprinter, ProMaster, or Transit), your budget range, and which features matter most. Then compare builders in your state using The Van Guide directory — each profile includes services, pricing tier, Google reviews, and contact information. Visit the shop if you can, ask to see completed builds, and get detailed written quotes from at least two or three builders before committing.`,
      },
      {
        question: "What questions should I ask a van conversion company?",
        answer: "Key questions include: What platforms do you build on? What's your typical build timeline? Do you offer a warranty on labor and materials? Can I see photos or visit completed builds? Are you RVIA-certified? What's included in the quoted price vs. what's an add-on? How do you handle change orders during the build? Do you provide a detailed build spec before starting?",
      },
      {
        question: "How much does a van conversion cost?",
        answer: "Van conversion costs range widely depending on the builder and scope. Budget builds typically run $15,000 to $30,000, mid-range conversions $30,000 to $80,000, and premium or luxury builds $80,000 to $150,000+. These figures cover the build labor and materials only — the base van is a separate purchase. Factors that affect price include electrical system size, cabinetry materials, plumbing complexity, and insulation type.",
      },
      {
        question: `How many van builders are listed in The Van Guide?`,
        answer: `The Van Guide currently lists ${builderCount} van conversion companies across ${stateCount} US states. The directory is updated regularly as new builders are verified and added. Each listing is editorially maintained with no paid placements.`,
      },
    ]
  : [];

// Serialize builder data for the React search island (includes lat/lng for map)
const searchData = builders.map((b) => ({
  id: b.id,
  name: b.name,
  slug: b.slug,
  state: b.state,
  city: b.city,
  tagline: b.tagline,
  platforms: b.platforms,
  services: b.services,
  price_tier: b.price_tier,
  description: b.description,
  logo_url: b.logo_url,
  verified: b.verified,
  review_rating: b.review_rating,
  review_count: b.review_count,
  website: b.website,
  year_founded: b.year_founded,
  build_style: b.build_style,
  latitude: b.latitude,
  longitude: b.longitude,
  profile_href: getShopProfileUrl(b, "/builders"),
}));
---

<DirectoryLayout
  title="Van Builder Directory"
  description={`Browse ${builderCount || ""} custom van conversion shops across ${stateCount || "the"} US states. Filter by platform, price range, services, and more.`.replace("  ", " ")}
  eyebrow="Directory"
  heading="Find a Van Conversion Builder"
  intro={builderCount > 0
    ? `Browse ${builderCount} van conversion shops across ${stateCount} states. Filter by platform, price range, services, and more.`
    : "An independent directory of US van conversion shops. No paid placements."}
  breadcrumbs={breadcrumbs}
  ogImage="/og/builders-hub.png"
  heroImage="/images/vintage-vw-van-sunset-lakeside.jpg"
  heroAlt="A vintage VW van parked at sunset by a lake"
>
  {/* Answerable content block for AI citation */}
  {builderCount > 0 && (
    <section class="mb-10 prose max-w-none">
      <p>
        The Van Guide is an independent directory of {builderCount} van conversion companies across {stateCount} US
        states. Every listing is free and editorially maintained — there are no paid placements or sponsored rankings.
        Browse by state, filter by van platform (Sprinter, ProMaster, Transit), price range, build style, or service
        specialty to find the right builder for your project.
      </p>
      <p>
        Each builder profile includes services offered, pricing tier, Google review ratings, portfolio photos, and
        direct contact information. Whether you're planning a weekend camper or a full-time live-in conversion, the
        directory helps you compare options and connect with builders directly.
      </p>
    </section>
  )}

  {builders.length === 0 ? (
    <div
      class="p-10 text-center border border-dashed"
      style="border-color: var(--color-border-strong); border-radius: var(--radius-lg); background: var(--color-surface);"
    >
      <div class="eyebrow mb-3">Coming soon</div>
      <h2 class="text-2xl mb-3">Directory is being built</h2>
      <p class="max-w-xl mx-auto" style="color: var(--color-text-muted);">
        We're gathering data on hundreds of US van conversion shops. This page will populate automatically as listings are added.
      </p>
    </div>
  ) : (
    <>
      {/* Unified search + map island */}
      <BuilderSearch client:idle builders={searchData} />

      {/* State quick-links */}
      {stateEntries.length > 0 && (
        <section class="mb-12">
          <div class="eyebrow mb-4">Browse by state</div>
          <div class="flex flex-wrap gap-2">
            {stateEntries.map(([state, count]) => (
              <a
                href={`/builders/${stateToSlug(state)}/`}
                class="px-3 py-1.5 font-sans-ui text-sm border no-underline transition-colors hover:border-current"
                style="border-color: var(--color-border-strong); border-radius: 999px; color: var(--color-text);"
              >
                {state} <span style="color: var(--color-text-subtle);">({count})</span>
              </a>
            ))}
          </div>
        </section>
      )}

      {/* Builder CTA banner */}
      <section
        class="mb-12 p-6 sm:p-8 border flex flex-col sm:flex-row sm:items-center gap-4 sm:gap-6"
        style="border-color: var(--color-primary); border-radius: var(--radius-lg); background: var(--color-surface);"
      >
        <div class="flex-1">
          <div class="eyebrow mb-2">For builders</div>
          <h2 class="text-xl sm:text-2xl mb-2">Own a van conversion shop?</h2>
          <p class="font-sans-ui text-sm" style="color: var(--color-text-muted);">
            Claim your existing listing or add your shop to the directory. Free profiles with photos, reviews, and direct customer inquiries.
          </p>
        </div>
        <div class="flex flex-col sm:flex-row gap-2 shrink-0">
          <a href="/builders/claim/" class="btn btn-accent text-center">Claim your listing</a>
          <a href="/builders/add/" class="btn btn-ghost text-center">Add your shop</a>
        </div>
      </section>

      {/* Category quick-links */}
      <section class="mb-12 grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
        <div>
          <div class="eyebrow mb-3">By platform</div>
          <ul class="space-y-1 font-sans-ui text-sm">
            <li><a href="/builders/platform/sprinter/">Sprinter</a></li>
            <li><a href="/builders/platform/promaster/">ProMaster</a></li>
            <li><a href="/builders/platform/transit/">Transit</a></li>
          </ul>
        </div>
        <div>
          <div class="eyebrow mb-3">By price range</div>
          <ul class="space-y-1 font-sans-ui text-sm">
            <li><a href="/builders/tier/budget/">Budget</a></li>
            <li><a href="/builders/tier/mid/">Mid-range</a></li>
            <li><a href="/builders/tier/premium/">Premium</a></li>
            <li><a href="/builders/tier/luxury/">Luxury</a></li>
          </ul>
        </div>
        <div>
          <div class="eyebrow mb-3">By style</div>
          <ul class="space-y-1 font-sans-ui text-sm">
            <li><a href="/builders/style/custom/">Custom builds</a></li>
            <li><a href="/builders/style/standard/">Standard builds</a></li>
          </ul>
        </div>
        <div>
          <div class="eyebrow mb-3">Popular services</div>
          <ul class="space-y-1 font-sans-ui text-sm">
            <li><a href="/builders/service/off-grid/">Off-grid</a></li>
            <li><a href="/builders/service/solar/">Solar</a></li>
            <li><a href="/builders/service/electrical/">Electrical</a></li>
          </ul>
        </div>
      </section>
    </>
  )}

  {/* FAQ section — visible content for AEO */}
  {hubFaqs.length > 0 && (
    <section class="mb-12">
      <h2 class="text-2xl mb-6">Frequently asked questions</h2>
      <dl class="space-y-6">
        {hubFaqs.map((faq) => (
          <div>
            <dt class="font-sans-ui font-semibold text-lg mb-2">{faq.question}</dt>
            <dd style="color: var(--color-text-muted);">{faq.answer}</dd>
          </div>
        ))}
      </dl>
    </section>
  )}

  {/* ItemList structured data */}
  {builders.length > 0 && (
    <script type="application/ld+json" set:html={JSON.stringify(itemListJsonLd(builders, "Van Conversion Builder Directory"))} />
  )}

  {/* FAQPage structured data */}
  {hubFaqs.length > 0 && (
    <script type="application/ld+json" set:html={JSON.stringify(faqPageJsonLd(hubFaqs))} />
  )}
</DirectoryLayout>
