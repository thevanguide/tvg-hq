---
import DirectoryLayout from "../../layouts/DirectoryLayout.astro";
import BuilderCard from "../../components/BuilderCard.astro";
import BuilderSearch from "../../components/BuilderSearch";
import { getAllBuilders, getDistinctStates, stateToSlug } from "../../lib/supabase";

const builders = await getAllBuilders();
const states = await getDistinctStates();

// Sort by review_rating desc, review_count as tiebreaker
const sorted = [...builders].sort((a, b) => {
  const rA = a.review_rating ?? 0;
  const rB = b.review_rating ?? 0;
  if (rB !== rA) return rB - rA;
  return (b.review_count ?? 0) - (a.review_count ?? 0);
});

// State counts for quick-links
const stateCounts = new Map<string, number>();
for (const b of builders) {
  stateCounts.set(b.state, (stateCounts.get(b.state) ?? 0) + 1);
}
const stateEntries = [...stateCounts.entries()].sort((a, b) => a[0].localeCompare(b[0]));

const builderCount = builders.length;
const stateCount = states.length;

const breadcrumbs = [
  { label: "Home", href: "/" },
  { label: "Builders", href: "/builders/" },
];

// Serialize builder data for the React search island
const searchData = builders.map((b) => ({
  id: b.id,
  name: b.name,
  slug: b.slug,
  state: b.state,
  city: b.city,
  tagline: b.tagline,
  platforms: b.platforms,
  services: b.services,
  price_tier: b.price_tier,
  description: b.description,
  logo_url: b.logo_url,
  verified: b.verified,
  review_rating: b.review_rating,
  review_count: b.review_count,
  website: b.website,
  year_founded: b.year_founded,
  build_style: b.build_style,
}));
---

<DirectoryLayout
  title="Van Builder Directory"
  description={`Browse ${builderCount || ""} custom van conversion shops across ${stateCount || "the"} US states. Filter by platform, price range, services, and more.`.replace("  ", " ")}
  eyebrow="Directory"
  heading="Find a Van Conversion Builder"
  intro={builderCount > 0
    ? `Browse ${builderCount} van conversion shops across ${stateCount} states. Filter by platform, price range, services, and more.`
    : "An independent directory of US van conversion shops. No paid placements."}
  breadcrumbs={breadcrumbs}
>
  {builders.length === 0 ? (
    <div
      class="p-10 text-center border border-dashed"
      style="border-color: var(--color-border-strong); border-radius: var(--radius-lg); background: var(--color-surface);"
    >
      <div class="eyebrow mb-3">Coming soon</div>
      <h2 class="text-2xl mb-3">Directory is being built</h2>
      <p class="max-w-xl mx-auto" style="color: var(--color-text-muted);">
        We're gathering data on hundreds of US van conversion shops. This page will populate automatically as listings are added.
      </p>
    </div>
  ) : (
    <>
      {/* React search island — client-side filtering */}
      <BuilderSearch client:load builders={searchData} />

      {/* State quick-links */}
      {stateEntries.length > 0 && (
        <section class="mb-12">
          <div class="eyebrow mb-4">Browse by state</div>
          <div class="flex flex-wrap gap-2">
            {stateEntries.map(([state, count]) => (
              <a
                href={`/builders/${stateToSlug(state)}/`}
                class="px-3 py-1.5 font-sans-ui text-sm border no-underline transition-colors hover:border-current"
                style="border-color: var(--color-border-strong); border-radius: 999px; color: var(--color-text);"
              >
                {state} <span style="color: var(--color-text-subtle);">({count})</span>
              </a>
            ))}
          </div>
        </section>
      )}

      {/* Category quick-links */}
      <section class="mb-12 grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
        <div>
          <div class="eyebrow mb-3">By platform</div>
          <ul class="space-y-1 font-sans-ui text-sm">
            <li><a href="/builders/platform/sprinter/">Sprinter</a></li>
            <li><a href="/builders/platform/promaster/">ProMaster</a></li>
            <li><a href="/builders/platform/transit/">Transit</a></li>
          </ul>
        </div>
        <div>
          <div class="eyebrow mb-3">By price range</div>
          <ul class="space-y-1 font-sans-ui text-sm">
            <li><a href="/builders/tier/budget/">Budget</a></li>
            <li><a href="/builders/tier/mid/">Mid-range</a></li>
            <li><a href="/builders/tier/premium/">Premium</a></li>
            <li><a href="/builders/tier/luxury/">Luxury</a></li>
          </ul>
        </div>
        <div>
          <div class="eyebrow mb-3">By style</div>
          <ul class="space-y-1 font-sans-ui text-sm">
            <li><a href="/builders/style/custom/">Custom builds</a></li>
            <li><a href="/builders/style/standard/">Standard builds</a></li>
          </ul>
        </div>
        <div>
          <div class="eyebrow mb-3">Popular services</div>
          <ul class="space-y-1 font-sans-ui text-sm">
            <li><a href="/builders/service/off-grid/">Off-grid</a></li>
            <li><a href="/builders/service/solar/">Solar</a></li>
            <li><a href="/builders/service/electrical/">Electrical</a></li>
          </ul>
        </div>
      </section>

      {/* All builders grid */}
      <section>
        <h2 class="text-2xl mb-6">All builders</h2>
        <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
          {sorted.map((b) => (
            <BuilderCard
              name={b.name}
              slug={b.slug}
              state={b.state}
              city={b.city ?? undefined}
              tagline={b.tagline ?? undefined}
              platforms={b.platforms}
              priceTier={b.price_tier ?? undefined}
              description={b.description ?? undefined}
              logoUrl={b.logo_url ?? undefined}
              verified={b.verified}
              reviewRating={b.review_rating ?? undefined}
              reviewCount={b.review_count ?? undefined}
              website={b.website ?? undefined}
            />
          ))}
        </div>
      </section>
    </>
  )}
</DirectoryLayout>
