---
import DirectoryLayout from "../../../layouts/DirectoryLayout.astro";
import BuilderCard from "../../../components/BuilderCard.astro";
import { getAllBuilders, getShopProfileUrl } from "../../../lib/supabase";
import { styleMeta, itemListJsonLd } from "../../../lib/seo";

export async function getStaticPaths() {
  const builders = await getAllBuilders();
  const styles = new Set<string>();
  for (const b of builders) {
    if (b.build_style) styles.add(b.build_style);
  }
  // Seed both values
  ["Custom", "Standard"].forEach((s) => styles.add(s));

  return [...styles].map((style) => ({
    params: { style: style.toLowerCase() },
    props: { styleName: style },
  }));
}

interface Props {
  styleName: string;
}
const { styleName } = Astro.props;

const all = await getAllBuilders();
const builders = all.filter(
  (b) => b.build_style && b.build_style.toLowerCase() === styleName.toLowerCase(),
);

const sorted = [...builders].sort((a, b) => {
  const rA = a.review_rating ?? 0;
  const rB = b.review_rating ?? 0;
  if (rB !== rA) return rB - rA;
  return (b.review_count ?? 0) - (a.review_count ?? 0);
});

const meta = styleMeta(styleName, builders.length);

const breadcrumbs = [
  { label: "Home", href: "/" },
  { label: "Builders", href: "/builders/" },
  { label: "Style", href: "/builders/" },
  { label: `${styleName} builds`, href: `/builders/style/${styleName.toLowerCase()}/` },
];

const otherStyle = styleName === "Custom" ? "Standard" : "Custom";
---

<DirectoryLayout
  title={meta.title}
  description={meta.description}
  eyebrow="Build style"
  heading={`${styleName} Van Conversion Builders`}
  intro={builders.length > 0
    ? `${builders.length} ${styleName.toLowerCase()} van conversion ${builders.length === 1 ? "builder" : "builders"} across the US.`
    : `No ${styleName.toLowerCase()} builders listed yet.`}
  breadcrumbs={breadcrumbs}
>
  {builders.length === 0 ? (
    <div
      class="p-10 text-center border border-dashed"
      style="border-color: var(--color-border-strong); border-radius: var(--radius-lg); background: var(--color-surface);"
    >
      <h2 class="text-xl mb-2">No listings yet</h2>
      <p style="color: var(--color-text-muted);">
        We're still categorizing builder styles.
      </p>
    </div>
  ) : (
    <div class="grid gap-4 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
      {sorted.map((b) => (
        <BuilderCard
          name={b.name}
          slug={b.slug}
          state={b.state}
          city={b.city ?? undefined}
          tagline={b.tagline ?? undefined}
          platforms={b.platforms}
          priceTier={b.price_tier ?? undefined}
          description={b.description ?? undefined}
          logoUrl={b.logo_url ?? undefined}
          verified={b.verified}
          reviewRating={b.review_rating ?? undefined}
          reviewCount={b.review_count ?? undefined}
          website={b.website ?? undefined}
          profileHref={getShopProfileUrl(b, "/builders")}
        />
      ))}
    </div>
  )}

  <nav class="mt-12 pt-8 border-t font-sans-ui text-sm flex flex-wrap gap-x-6 gap-y-2" style="border-color: var(--color-border);">
    <a href="/builders/">← All builders</a>
    <a href={`/builders/style/${otherStyle.toLowerCase()}/`}>{otherStyle} builders</a>
    <a href="/builders/platform/sprinter/">Sprinter builders</a>
    <a href="/builders/tier/luxury/">Luxury builders</a>
  </nav>

  {/* ItemList structured data */}
  {builders.length > 0 && (
    <script type="application/ld+json" set:html={JSON.stringify(itemListJsonLd(sorted, `${styleName} Van Conversion Builders`))} />
  )}
</DirectoryLayout>
