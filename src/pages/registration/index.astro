---
import DirectoryLayout from "../../layouts/DirectoryLayout.astro";
import ArticleCard from "../../components/ArticleCard.astro";
import { getCollection } from "astro:content";

const entries = (await getCollection("registration", ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());
---

<DirectoryLayout
  title="Van Registration Guide"
  description="State-by-state registration and titling guides for custom van conversions."
  eyebrow="Registration"
  heading="Registering a custom van, state by state."
  intro="Some states make it easy. Others make it a nightmare. Here's what you need to know about titling, RV reclassification, and registration for conversion vans."
>
  {entries.length === 0 ? (
    <p style="color: var(--color-text-muted);">State guides coming soon.</p>
  ) : (
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {entries.map((entry) => (
        <ArticleCard
          href={`/registration/${entry.slug}/`}
          title={entry.data.title}
          description={entry.data.description}
          publishDate={entry.data.publishDate}
          category={entry.data.category}
        />
      ))}
    </div>
  )}
</DirectoryLayout>
