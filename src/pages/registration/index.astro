---
import BaseLayout from "../../layouts/BaseLayout.astro";
import StateSearch from "../../components/StateSearch";
import { getCollection } from "astro:content";

const all = await getCollection("registration", ({ data }) => !data.draft);
const pillar = all.find((e) => e.data.pillar);
const others = all
  .filter((e) => !e.data.pillar)
  .sort((a, b) => a.data.title.localeCompare(b.data.title));

const { Content: PillarContent } = pillar
  ? await pillar.render()
  : { Content: null };

const title = pillar?.data.title ?? "Van Registration Guide";
const description =
  pillar?.data.description ??
  "State-by-state titling and registration guides for van conversions.";
const lastUpdated = pillar?.data.lastUpdated;

const fmtDate = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "long" });
---

<BaseLayout title={title} description={description} ogType="article" ogImage="/og/registration-hub.png">
  <article class="py-14 md:py-20">
    <header class="container-read mb-10">
      <div class="eyebrow mb-4">Registration</div>
      <h1 class="text-3xl md:text-5xl leading-tight mb-5">{title}</h1>
      <p class="text-lg md:text-xl leading-relaxed" style="color: var(--color-text-muted);">
        {description}
      </p>
      {lastUpdated && (
        <div class="mt-6 font-sans-ui text-sm" style="color: var(--color-text-subtle);">
          <time datetime={lastUpdated.toISOString()}>Last updated {fmtDate(lastUpdated)}</time>
        </div>
      )}
      <hr />
    </header>
    {PillarContent && (
      <div class="container-read prose">
        <PillarContent />
      </div>
    )}
  </article>

  {others.length > 0 && (
    <section id="state-guides" class="border-t py-14 md:py-20" style="border-color: var(--color-border); background: var(--color-surface);">
      <div class="container-wide">
        <h2 class="text-2xl md:text-4xl mb-3">State guides</h2>
        <p class="text-base md:text-lg mb-8 md:mb-10 max-w-2xl" style="color: var(--color-text-muted);">
          Detailed retitling walkthroughs for each US state.
        </p>
        <StateSearch
          client:load
          states={others.map((entry) => ({
            href: `/registration/${entry.slug}/`,
            title: entry.data.title,
            description: entry.data.description,
            lastUpdated: entry.data.lastUpdated?.toISOString(),
            cluster: entry.data.cluster,
          }))}
        />
      </div>
    </section>
  )}
</BaseLayout>
