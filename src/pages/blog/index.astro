---
import DirectoryLayout from "../../layouts/DirectoryLayout.astro";
import ArticleCard from "../../components/ArticleCard.astro";
import { getCollection } from "astro:content";

const entries = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());
---

<DirectoryLayout
  title="Blog"
  description="Editorial coverage of van conversions, builder news, and ownership."
  eyebrow="Blog"
  heading="Editorial coverage from The Van Guide."
  intro="Longer pieces on van ownership, builder profiles, and the van conversion industry."
>
  {entries.length === 0 ? (
    <p style="color: var(--color-text-muted);">Posts coming soon.</p>
  ) : (
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {entries.map((entry) => (
        <ArticleCard
          href={`/blog/${entry.slug}/`}
          title={entry.data.title}
          description={entry.data.description}
          publishDate={entry.data.publishDate}
          category={entry.data.category}
        />
      ))}
    </div>
  )}
</DirectoryLayout>
